<div class="mb-8">
  <p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Account</p>
  <h1 class="font-headline text-headline-md text-primary">Change Password</h1>
</div>

<div class="max-w-xl bg-surface-container-lowest border border-outline-variant rounded-lg p-8">
  <% if (error) { %>
    <div class="mb-6 p-4 bg-error/10 border border-error rounded-lg">
      <p class="text-error font-body text-body-sm"><%= error %></p>
    </div>
  <% } %>

  <form method="POST" action="/portal/profile/change-password" class="space-y-6">
    <div>
      <label class="block text-on-surface-variant text-label-sm mb-2">Current password *</label>
      <input type="password" name="current_password" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
    </div>

    <div class="bg-surface-container-highest p-4 rounded-lg">
      <p class="text-on-surface-variant text-label-sm font-bold mb-3">New password requirements:</p>
      <ul class="space-y-2 text-body-sm">
        <li class="text-on-surface-variant">• At least 8 characters long</li>
        <li class="text-on-surface-variant">• At least one uppercase letter (A-Z)</li>
        <li class="text-on-surface-variant">• At least one number (0-9)</li>
        <li class="text-on-surface-variant">• At least one special character (!@#$%^&*)</li>
      </ul>
    </div>

    <div>
      <label class="block text-on-surface-variant text-label-sm mb-2">New password *</label>
      <input type="password" name="new_password" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
      <p class="text-on-surface-variant/60 text-label-xs mt-2">Create a strong password you haven't used before</p>
    </div>

    <div>
      <label class="block text-on-surface-variant text-label-sm mb-2">Confirm new password *</label>
      <input type="password" name="confirm_password" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
    </div>

    <div class="flex gap-3 pt-6 border-t border-outline-variant">
      <button type="submit" class="px-4 py-2 bg-primary text-on-primary rounded-lg font-body text-body-md hover:bg-primary/90 transition">
        Change Password
      </button>
      <a href="/portal/profile" class="px-4 py-2 border border-outline bg-surface-container-lowest text-primary rounded-lg font-body text-body-md hover:bg-surface-container transition">
        Cancel
      </a>
    </div>
  </form>

  <div class="mt-8 pt-6 border-t border-outline-variant/40">
    <p class="text-on-surface-variant text-label-sm mb-3">💡 <strong>Password security tips:</strong></p>
    <ul class="text-body-sm text-on-surface-variant space-y-1">
      <li>• Never reuse a password</li>
      <li>• Don't use personal information (name, DOB, etc.)</li>
      <li>• Use a mix of uppercase, lowercase, numbers, and symbols</li>
      <li>• If you suspect your account is compromised, change immediately</li>
    </ul>
  </div>
</div>
