<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <style> @media print { .no-print { display:none !important; } body { background:#fff; } } </style>
</head>
<body class="bg-surface-container-low min-h-screen flex flex-col items-center justify-center p-6 font-body">
  <div class="bg-surface-container-lowest w-full max-w-3xl border-[6px] border-double border-secondary p-10 md:p-16 text-center relative">
    <div class="absolute top-4 left-4 w-16 h-16 border-t-4 border-l-4 border-secondary/40"></div>
    <div class="absolute bottom-4 right-4 w-16 h-16 border-b-4 border-r-4 border-secondary/40"></div>

    <span class="material-symbols-outlined text-secondary" style="font-size:56px; font-variation-settings:'FILL' 1;">school</span>
    <p class="font-tagline text-tagline text-secondary uppercase tracking-[0.3em] mt-2">Global Diaspora Christian University</p>
    <h1 class="font-display text-display-lg-mobile md:text-display-lg text-primary mt-8 mb-2">Certificate of Completion</h1>
    <p class="font-body text-body-md text-on-surface-variant mb-8">This is to certify that</p>
    <p class="font-headline text-headline-md text-primary border-b border-outline-variant inline-block px-8 pb-2 mb-8"><%= holder %></p>
    <p class="font-body text-body-md text-on-surface-variant mb-2">has successfully completed</p>
    <p class="font-headline text-headline-sm text-primary mb-10"><%= cert.title.replace('Certificate of Completion — ','') %></p>

    <div class="flex justify-between items-end mt-12 text-left">
      <div>
        <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Issued</p>
        <p class="font-bold text-primary"><%= formatDate(cert.issued_at) %></p>
      </div>
      <div class="text-center">
        <p class="font-display italic text-headline-sm text-primary">GDCU</p>
        <div class="w-40 border-t border-on-surface-variant pt-1"><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Registrar</p></div>
      </div>
      <div class="text-right">
        <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Reference</p>
        <p class="font-bold text-primary"><%= cert.reference %></p>
      </div>
    </div>
  </div>

  <div class="no-print mt-6 flex gap-4">
    <button onclick="window.print()" class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><span class="material-symbols-outlined align-middle text-base">print</span> Print / Save PDF</button>
    <a href="/portal/certificates" class="border border-outline text-primary px-6 py-2 rounded font-bold bg-surface-container-lowest">Back</a>
  </div>
</body>
</html>
