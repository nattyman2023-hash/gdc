<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Academic Resources</p><h1 class="font-headline text-headline-md text-primary">Library &amp; Resources</h1></div>

<form method="get" class="flex flex-wrap gap-3 mb-6">
  <input name="q" value="<%= filters.q %>" placeholder="Search resources…" class="px-3 py-2 rounded border border-outline outline-none focus:border-primary min-w-[220px]" />
  <select name="type" class="px-3 py-2 rounded border border-outline outline-none focus:border-primary">
    <option value="">All types</option>
    <% types.forEach(function(t){ %><option value="<%= t %>" <%= filters.type===t?'selected':'' %>><%= t %></option><% }) %>
  </select>
  <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold">Filter</button>
  <a href="/portal/library" class="px-5 py-2 rounded font-bold border border-outline text-on-surface-variant">Reset</a>
</form>

<% const icons = { document:'description', link:'link', video:'smart_display', book:'menu_book', journal:'article' }; %>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% if (!resources.length) { %><p class="text-on-surface-variant col-span-full">No resources found.</p><% } %>
  <% resources.forEach(function(r){ %>
  <a href="<%= r.url %>" target="_blank" rel="noopener" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary transition-colors flex flex-col">
    <div class="flex items-center justify-between mb-3">
      <div class="w-10 h-10 bg-secondary-container flex items-center justify-center rounded"><span class="material-symbols-outlined text-on-secondary-container"><%= icons[r.type] || 'link' %></span></div>
      <span class="font-tagline text-[10px] text-on-surface-variant uppercase"><%= r.type %></span>
    </div>
    <% if (r.category) { %><span class="font-tagline text-label-sm text-secondary uppercase"><%= r.category %></span><% } %>
    <h3 class="font-headline text-headline-sm text-primary mb-1"><%= r.title %></h3>
    <p class="text-on-surface-variant text-sm flex-1"><%= truncate(r.description, 90) %></p>
    <p class="text-secondary font-bold text-sm mt-3 inline-flex items-center gap-1">Open <span class="material-symbols-outlined text-base">open_in_new</span></p>
  </a>
  <% }) %>
</div>
