<div class="mb-8">
  <p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Account</p>
  <h1 class="font-headline text-headline-md text-primary">My Profile</h1>
</div>

<% const isEditing = typeof edit !== 'undefined' ? edit : false;
const getFlagEmoji = (function() {
  const map = { 'Kenya': '🇰🇪', 'UK': '🇬🇧', 'USA': '🇺🇸', 'Nigeria': '🇳🇬', 'Ghana': '🇬🇭', 'South Africa': '🇿🇦', 'Rwanda': '🇷🇼', 'Uganda': '🇺🇬', 'Tanzania': '🇹🇿', 'Ethiopia': '🇪🇹', 'Zambia': '🇿🇲', 'Zimbabwe': '🇿🇼', 'Canada': '🇨🇦', 'Australia': '🇦🇺', 'Germany': '🇩🇪', 'France': '🇫🇷', 'India': '🇮🇳', 'Brazil': '🇧🇷', 'Jamaica': '🇯🇲', 'Trinidad and Tobago': '🇹🇹', 'Barbados': '🇧🇧' };
  return function(c) { return map[c] || '🌍'; };
})(); %>

<% if (!isEditing) { %>
  <!-- Read-only profile view (enhanced) -->
  <div class="grid lg:grid-cols-3 gap-6">
    <!-- Profile Card -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden">
      <div class="relative h-32 bg-gradient-to-br from-primary to-primary-container">
        <div class="absolute -bottom-12 left-5">
          <div class="w-28 h-28 rounded-full border-4 border-surface-container-lowest bg-secondary-container text-on-secondary-container flex items-center justify-center text-3xl font-bold overflow-hidden">
            <% if (user.photo_url) { %>
            <img src="<%= user.photo_url %>" alt="" class="w-full h-full object-cover" />
            <% } else { %>
            <%= user.first_name.charAt(0) %><%= user.last_name.charAt(0) %>
            <% } %>
          </div>
        </div>
      </div>
      <div class="pt-16 pb-5 px-5">
        <h1 class="font-headline text-headline-md text-primary"><%= user.first_name %> <%= user.last_name %></h1>
        <p class="text-sm text-on-surface-variant inline-flex items-center gap-1">
          <% if (user.country) { %><%= getFlagEmoji(user.country) %><% } %>
          <%= user.email %>
        </p>
        <p class="font-tagline text-label-sm text-secondary uppercase mt-1"><%= user.role %></p>
        <% if (user.student_id) { %><p class="text-xs text-on-surface-variant mt-1">ID: <%= user.student_id %></p><% } %>

        <!-- Achievements -->
        <% if (achievements && achievements.length) { %>
        <div class="mt-5">
          <p class="font-tagline text-label-sm text-on-surface-variant uppercase mb-2">Achievements</p>
          <div class="flex flex-wrap gap-2">
            <% achievements.forEach(function(a){ %>
            <span class="inline-flex items-center gap-1 bg-secondary-fixed/30 text-secondary text-xs px-2.5 py-1.5 rounded-full font-bold" title="<%= a.description || a.title %>">
              <span class="material-symbols-outlined text-sm"><%= a.badge_icon || 'emoji_events' %></span>
              <%= a.title %>
            </span>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Cohorts -->
        <% if (cohorts && cohorts.length) { %>
        <div class="mt-5">
          <p class="font-tagline text-label-sm text-on-surface-variant uppercase mb-2">My Cohorts</p>
          <div class="space-y-2">
            <% cohorts.forEach(function(c){ %>
            <div class="flex items-center gap-2 bg-surface-container-low rounded-lg p-2.5">
              <span class="material-symbols-outlined text-secondary text-base">groups</span>
              <div>
                <p class="text-sm font-bold text-primary"><%= c.name %></p>
                <p class="text-xs text-on-surface-variant">Year <%= c.year %></p>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Details -->
    <div class="lg:col-span-2 bg-surface-container-lowest border border-outline-variant rounded-lg p-8">
      <dl class="divide-y divide-outline-variant/40">
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Email</dt><dd class="font-bold text-primary"><%= user.email %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Country</dt><dd class="font-bold text-primary"><%= user.country ? getFlagEmoji(user.country) + ' ' + user.country : '—' %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Phone</dt><dd class="font-bold text-primary"><%= user.phone || '—' %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Date of Birth</dt><dd class="font-bold text-primary"><%= user.date_of_birth ? formatDate(user.date_of_birth) : '—' %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Role</dt><dd class="font-bold text-primary capitalize"><%= user.role %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Status</dt><dd class="font-bold text-primary capitalize"><%= user.status %></dd></div>
        <div class="flex justify-between py-3"><dt class="text-on-surface-variant">Member since</dt><dd class="font-bold text-primary"><%= formatDate(user.created_at) %></dd></div>
        <% if (user.bio) { %><div class="py-3"><dt class="text-on-surface-variant mb-1">Bio</dt><dd class="font-bold text-primary"><%= user.bio %></dd></div><% } %>
      </dl>
      <div class="flex gap-3 mt-8">
        <a href="/portal/profile?edit=1" class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-bold hover:bg-primary/90 transition">
          <span class="material-symbols-outlined text-base">edit</span>
          Edit Profile
        </a>
        <a href="/portal/profile/change-password" class="inline-flex items-center gap-2 px-4 py-2 border border-outline-variant text-primary rounded-lg font-bold hover:bg-surface-container transition">
          <span class="material-symbols-outlined text-base">lock</span>
          Change Password
        </a>
      </div>
    </div>
  </div>

<% } else { %>
  <!-- Edit profile form -->
  <div class="max-w-xl bg-surface-container-lowest border border-outline-variant rounded-lg p-8">
    <form method="POST" action="/portal/profile" enctype="multipart/form-data" class="space-y-6">
      <div>
          <label class="block text-on-surface-variant text-label-sm mb-2">Profile Photo</label>
          <div class="flex items-center gap-4">
            <div class="w-20 h-20 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center text-2xl font-bold overflow-hidden">
              <% if (user.photo_url) { %>
              <img src="<%= user.photo_url %>" alt="" class="w-full h-full object-cover" />
              <% } else { %>
              <%= user.first_name.charAt(0) %><%= user.last_name.charAt(0) %>
              <% } %>
            </div>
            <input type="file" name="photo" accept="image/*" class="text-sm" />
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <label class="block text-on-surface-variant text-label-sm mb-2">First name *</label>
          <input type="text" name="first_name" value="<%= user.first_name %>" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
        </div>
        <div>
          <label class="block text-on-surface-variant text-label-sm mb-2">Last name *</label>
          <input type="text" name="last_name" value="<%= user.last_name %>" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
        </div>
      </div>
      
      <div>
        <label class="block text-on-surface-variant text-label-sm mb-2">Email *</label>
        <select name="country" class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
            <option value="">— Select —</option>
            <% ['Kenya', 'UK', 'USA', 'Nigeria', 'Ghana', 'South Africa', 'Rwanda', 'Uganda', 'Tanzania', 'Ethiopia', 'Zambia', 'Zimbabwe', 'Canada', 'Australia', 'Germany', 'France', 'India', 'Brazil', 'Jamaica', 'Trinidad and Tobago', 'Barbados', 'Other'].forEach(function(c){ %>
            <option value="<%= c %>" <%= user.country === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-on-surface-variant text-label-sm mb-2">Phone number</label>
          <input type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="+254 712 345 678" class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
        </div>
        <div>
          <label class="block text-on-surface-variant text-label-sm mb-2">Date of Birth</label>
          <input type="date" name="date_of_birth" value="<%= user.date_of_birth ? new Date(user.date_of_birth).toISOString().split('T')[0] : '' %>" class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
        </div>
      </div>

      <div>
        <label class="block text-on-surface-variant text-label-sm mb-2">Bio</label>
        <textarea name="bio" rows="3" class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow" placeholder="Tell us about yourself…"><%= user.bio || '' %></textarea>
      </div>

      <div>
        <label class="block text-on-surface-variant text-label-sm mb-2">Email *</label>
        <input type="email" name="email" value="<%= user.email %>" required class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
      </div>
      
      <div>
        <label class="block text-on-surface-variant text-label-sm mb-2">Phone number</label>
        <input type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="+44 7700 123456" class="w-full px-4 py-3 rounded-lg border border-outline bg-surface-container-lowest outline-none focus:border-primary focus:ring-2 focus:ring-secondary/40 transition-shadow">
      </div>

      <div class="flex gap-3 pt-6 border-t border-outline-variant">
        <button type="submit" class="px-4 py-2 bg-primary text-on-primary rounded-lg font-body text-body-md hover:bg-primary/90 transition">
          Save Changes
        </button>
        <a href="/portal/profile" class="px-4 py-2 border border-outline bg-surface-container-lowest text-primary rounded-lg font-body text-body-md hover:bg-surface-container transition">
          Cancel
        </a>
      </div>
    </form>
  </div>
<% } %>
