<div class="mb-8">
  <p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Achievements</p>
  <h1 class="font-headline text-headline-md text-primary">My Certificates</h1>
</div>

<% if (claimable.length) { %>
<div class="mb-8">
  <h2 class="font-headline text-headline-sm text-primary mb-3">Ready to claim</h2>
  <div class="space-y-3">
    <% claimable.forEach(function(c){ %>
    <div class="bg-secondary-fixed border border-secondary rounded-lg p-5 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-secondary text-3xl" style="font-variation-settings:'FILL' 1;">workspace_premium</span>
        <div><p class="font-bold text-on-secondary-fixed"><%= c.title %></p><p class="text-sm text-on-secondary-fixed/80">You have completed this course.</p></div>
      </div>
      <form action="/portal/courses/<%= c.course_id %>/certificate" method="post"><button class="bg-primary text-on-primary px-5 py-2 rounded font-bold shrink-0">Claim</button></form>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<h2 class="font-headline text-headline-sm text-primary mb-3">Issued certificates</h2>
<% if (!certificates.length) { %>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-8 text-center text-on-surface-variant">No certificates yet. Complete a course to earn one.</div>
<% } %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <% certificates.forEach(function(c){ %>
  <div class="bg-surface-container-lowest border-t-4 border-secondary border border-outline-variant rounded-lg p-6">
    <div class="flex items-start justify-between">
      <span class="material-symbols-outlined text-secondary text-4xl" style="font-variation-settings:'FILL' 1;">workspace_premium</span>
      <span class="font-tagline text-[11px] text-on-surface-variant uppercase"><%= formatDate(c.issued_at) %></span>
    </div>
    <h3 class="font-headline text-headline-sm text-primary mt-3"><%= c.title %></h3>
    <p class="font-tagline text-label-sm text-on-surface-variant mt-1">Ref: <%= c.reference %></p>
    <a href="/portal/certificates/<%= c.reference %>" target="_blank" class="inline-flex items-center gap-1 text-secondary font-bold mt-4 text-sm">View &amp; print <span class="material-symbols-outlined text-base">open_in_new</span></a>
  </div>
  <% }) %>
</div>
