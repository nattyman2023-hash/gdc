<%- include('../partials/page-hero', { heroTitle: 'Academic Programmes', heroTagline: 'Educate · Equip · Empower', heroText: 'Affordable, online, Christ-centred programmes across theology, leadership and enterprise — open to learners in any nation.' }) %>

<section class="py-16 lg:py-20 bg-background">
  <div class="max-w-container-max mx-auto px-margin-mobile lg:px-margin-desktop">

    <!-- Filters -->
    <form method="get" class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 mb-14 grid grid-cols-1 md:grid-cols-4 gap-4 items-end shadow-sm">
      <div class="md:col-span-2">
        <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Search</label>
        <input name="q" value="<%= filters.q %>" placeholder="Search programmes…" class="w-full px-3 py-2.5 rounded-lg border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary transition" />
      </div>
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Level</label>
        <select name="level" class="w-full px-3 py-2.5 rounded-lg border border-outline outline-none focus:border-primary bg-surface-container-lowest">
          <option value="">All levels</option>
          <% levels.forEach(function(l){ %><option value="<%= l %>" <%= filters.level===l?'selected':'' %>><%= l %></option><% }) %>
        </select>
      </div>
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">School</label>
        <select name="school" class="w-full px-3 py-2.5 rounded-lg border border-outline outline-none focus:border-primary bg-surface-container-lowest">
          <option value="">All schools</option>
          <% schools.forEach(function(s){ %><option value="<%= s %>" <%= filters.school===s?'selected':'' %>><%= s %></option><% }) %>
        </select>
      </div>
      <div class="md:col-span-4 flex gap-3">
        <button class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-bold hover:opacity-90 active:scale-95 transition">Filter</button>
        <a href="/programs" class="px-6 py-2.5 rounded-lg font-bold border border-outline text-on-surface-variant hover:bg-surface-container transition">Reset</a>
      </div>
    </form>

    <% if (!programs.length) { %>
      <p class="text-on-surface-variant text-center py-12">No programmes match your filters. <a href="/programs" class="text-secondary font-bold underline">Clear filters</a>.</p>
    <% } %>

    <%
      // Group programmes by level into clear sections (undergrad → masters → doctoral → short courses).
      const levelGroups = [
        { name: 'Undergraduate Degrees', blurb: 'Build strong biblical and academic foundations.', levels: ['Undergraduate'] },
        { name: "Master's Degrees", blurb: 'Deepen your expertise and advance your calling.', levels: ['Masters'] },
        { name: 'Doctoral Research', blurb: 'Original scholarship at the highest level.', levels: ['Doctorate'] },
        { name: 'Certificates & Diplomas', blurb: 'Focused, flexible study to get started.', levels: ['Certificate', 'Diploma'] },
      ];
      const knownLevels = levelGroups.reduce((a, g) => a.concat(g.levels), []);
      const grouped = levelGroups
        .map((g) => ({ name: g.name, blurb: g.blurb, items: programs.filter((p) => g.levels.includes(p.level)) }))
        .filter((g) => g.items.length);
      const other = programs.filter((p) => !knownLevels.includes(p.level));
      if (other.length) grouped.push({ name: 'Other Programmes', blurb: '', items: other });
    %>

    <% grouped.forEach(function(group, gi){ %>
    <div class="<%= gi > 0 ? 'mt-20' : '' %>">
      <div class="flex flex-wrap items-end justify-between gap-3 mb-8">
        <div>
          <h2 class="font-display text-headline-md text-primary"><%= group.name %></h2>
          <% if (group.blurb) { %><p class="text-on-surface-variant mt-1"><%= group.blurb %></p><% } %>
          <div class="w-16 h-1 bg-secondary mt-4 rounded-full"></div>
        </div>
        <span class="font-tagline text-label-sm text-on-surface-variant uppercase tracking-wider"><%= group.items.length %> programme<%= group.items.length===1?'':'s' %></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% group.items.forEach(function(p){ %>
        <a href="/programs/<%= p.slug %>" class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden flex flex-col hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="relative h-44 overflow-hidden bg-primary-container">
            <img src="<%= imageFor('program', p) %>" alt="" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/55 via-primary/10 to-transparent"></div>
            <span class="absolute top-3 left-3 font-tagline text-[10px] bg-primary/85 text-on-primary px-2.5 py-1 rounded uppercase tracking-wider"><%= p.level %></span>
            <% if (p.featured) { %><span class="absolute top-3 right-3 font-tagline text-[10px] bg-secondary text-on-secondary px-2.5 py-1 rounded uppercase tracking-wider">Featured</span><% } %>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <span class="font-tagline text-label-sm text-secondary uppercase mb-2 tracking-wider"><%= p.school %></span>
            <h3 class="font-headline text-headline-sm text-primary mb-3 leading-snug group-hover:text-secondary transition-colors"><%= p.title %></h3>
            <p class="text-on-surface-variant text-body-md mb-6 flex-1 leading-relaxed"><%= truncate(p.summary, 120) %></p>
            <div class="flex items-center justify-between border-t border-outline-variant/50 pt-4 text-sm">
              <span class="text-on-surface-variant inline-flex items-center gap-1"><span class="material-symbols-outlined text-base align-middle">schedule</span> <%= p.duration || 'Flexible' %></span>
              <% if (p.semester_credits) { %>
              <span class="text-on-surface-variant inline-flex items-center gap-1"><span class="material-symbols-outlined text-base align-middle">school</span> <%= p.semester_credits %> cr</span>
              <% } %>
              <span class="font-bold text-primary"><%= formatMoney(p.tuition, p.tuition_currency) %></span>
            </div>
            <span class="mt-4 inline-flex items-center gap-1.5 text-secondary font-bold text-sm group-hover:gap-3 transition-all">Explore programme <span class="material-symbols-outlined text-base">arrow_forward</span></span>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
    <% }) %>

  </div>
</section>
