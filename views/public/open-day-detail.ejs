<section class="bg-primary text-on-primary py-16">
  <div class="max-w-container-max mx-auto px-margin-mobile lg:px-margin-desktop">
    <a href="/open-days" class="inline-flex items-center gap-1 text-secondary-fixed-dim hover:text-secondary-fixed text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All open days</a>
    <p class="font-tagline text-tagline text-secondary-fixed uppercase mb-2">Open Day</p>
    <h1 class="font-display text-display-lg-mobile md:text-display-lg leading-tight mb-4"><%= openDay.title %></h1>
    <div class="flex flex-wrap gap-x-8 gap-y-2 text-on-primary-container">
      <span class="inline-flex items-center gap-2"><span class="material-symbols-outlined">calendar_month</span> <%= formatDateTime(openDay.starts_at) %><% if (openDay.ends_at) { %> – <%= new Date(openDay.ends_at).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}) %><% } %></span>
      <span class="inline-flex items-center gap-2"><span class="material-symbols-outlined"><%= openDay.is_online ? 'videocam' : 'location_on' %></span> <%= openDay.is_online ? 'Online event' : (openDay.location || 'Venue TBC') %></span>
    </div>
  </div>
</section>

<section class="py-16 bg-surface-bright">
  <div class="max-w-container-max mx-auto px-margin-mobile lg:px-margin-desktop grid lg:grid-cols-5 gap-12">
    <div class="lg:col-span-3">
      <h2 class="font-headline text-headline-md text-primary mb-4">About this open day</h2>
      <div class="font-body text-body-md text-on-surface-variant leading-relaxed whitespace-pre-line"><%= openDay.description || 'Come and meet our team, hear about our programmes and the way we teach, and get your questions answered. Everyone is welcome.' %></div>
    </div>

    <div class="lg:col-span-2">
      <div id="register" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 sticky top-28">
        <% if (done) { %>
          <div class="text-center py-6">
            <span class="material-symbols-outlined text-secondary text-5xl">check_circle</span>
            <h3 class="font-headline text-headline-sm text-primary mt-2 mb-1">You're registered!</h3>
            <p class="text-on-surface-variant text-sm">We've emailed you the details. We look forward to seeing you.</p>
            <a href="/programs" class="inline-block mt-5 bg-secondary text-on-secondary px-6 py-3 rounded font-bold">Explore programmes</a>
          </div>
        <% } else if (full) { %>
          <div class="text-center py-6">
            <span class="material-symbols-outlined text-on-surface-variant text-5xl">event_busy</span>
            <h3 class="font-headline text-headline-sm text-primary mt-2 mb-1">This open day is full</h3>
            <p class="text-on-surface-variant text-sm mb-4">Registration has reached capacity. See our other open days or get in touch.</p>
            <a href="/open-days" class="inline-block bg-secondary text-on-secondary px-6 py-3 rounded font-bold">Other open days</a>
          </div>
        <% } else { %>
          <h3 class="font-headline text-headline-sm text-primary mb-1">Register your place</h3>
          <p class="text-on-surface-variant text-sm mb-4">It's free. We'll email you the joining details.</p>
          <form action="/open-days/<%= openDay.slug %>/register" method="post" class="space-y-3" novalidate>
            <div>
              <input name="first_name" value="<%= form.first_name || '' %>" placeholder="First name *" class="w-full px-3 py-2 rounded border <%= errors.first_name ? 'border-error' : 'border-outline' %> outline-none focus:border-primary" />
              <% if (errors.first_name) { %><p class="text-error text-xs mt-1"><%= errors.first_name %></p><% } %>
            </div>
            <input name="last_name" value="<%= form.last_name || '' %>" placeholder="Last name" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
            <div>
              <input name="email" type="email" value="<%= form.email || '' %>" placeholder="Email address *" class="w-full px-3 py-2 rounded border <%= errors.email ? 'border-error' : 'border-outline' %> outline-none focus:border-primary" />
              <% if (errors.email) { %><p class="text-error text-xs mt-1"><%= errors.email %></p><% } %>
            </div>
            <input name="phone" value="<%= form.phone || '' %>" placeholder="Phone (optional)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
            <input name="country" value="<%= form.country || '' %>" placeholder="Country (optional)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
            <textarea name="message" rows="2" placeholder="Anything you'd like us to know? (optional)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= form.message || '' %></textarea>
            <button class="w-full bg-secondary text-on-secondary px-6 py-3 rounded font-bold hover:opacity-90">Register for free</button>
            <p class="text-[11px] text-on-surface-variant text-center">By registering you agree to be contacted by our admissions team.</p>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</section>
