<%- include('../partials/page-hero', { heroTitle: 'Frequently Asked Questions', heroTagline: 'Help Hub', heroText: 'Answers to common questions about studying with GDCU.' }) %>

<section class="py-16 bg-surface-bright">
  <div class="max-w-3xl mx-auto px-margin-mobile lg:px-margin-desktop">
    <% Object.keys(grouped).forEach(function(category){ %>
    <div class="mb-10">
      <h2 class="font-headline text-headline-sm text-secondary mb-4 uppercase tracking-wide"><%= category %></h2>
      <div class="space-y-3">
        <% grouped[category].forEach(function(f){ %>
        <details class="bg-surface-container-lowest border border-outline-variant rounded-lg group">
          <summary class="flex justify-between items-center cursor-pointer px-6 py-4 font-bold text-primary list-none">
            <span><%= f.question %></span>
            <span class="material-symbols-outlined text-secondary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 pb-5 text-on-surface-variant text-body-md leading-relaxed"><%= f.answer %></div>
        </details>
        <% }) %>
      </div>
    </div>
    <% }) %>

    <div class="bg-primary text-on-primary rounded-lg p-8 text-center mt-12">
      <h3 class="font-headline text-headline-sm mb-2">Still have questions?</h3>
      <p class="text-on-primary-container mb-6">Our team is happy to help with anything not covered here.</p>
      <a href="/contact" class="inline-block bg-secondary text-on-secondary px-8 py-3 rounded font-bold hover:opacity-90">Contact Us</a>
    </div>
  </div>
</section>
