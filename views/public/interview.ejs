<section class="py-16 bg-surface-bright min-h-[70vh]">
  <div class="max-w-3xl mx-auto px-margin-mobile lg:px-margin-desktop">
    <div class="text-center mb-8">
      <p class="font-tagline text-tagline text-secondary uppercase tracking-widest">Admissions</p>
      <h1 class="font-display text-display-lg-mobile md:text-headline-md text-primary mt-2">Schedule Your Academic Interview</h1>
      <p class="text-on-surface-variant mt-2">Hello <%= application.first_name %>, please choose a mentor and a time that suits you.</p>
    </div>

    <% if (booked) { %>
      <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-8 text-center shadow-sm">
        <span class="material-symbols-outlined text-secondary" style="font-size:48px; font-variation-settings:'FILL' 1;">event_available</span>
        <h2 class="font-headline text-headline-md text-primary mt-2">Your interview is booked</h2>
        <p class="font-body text-body-lg text-on-surface-variant mt-3"><strong class="text-primary"><%= formatDateTime(booked.scheduled_at) %></strong></p>
        <p class="text-on-surface-variant"><%= booked.mode==='online'?'Online':'In person' %><% if (booked.iv_first) { %> · with Dr. <%= booked.iv_first %> <%= booked.iv_last %><% } %></p>
        <% if (booked.location) { %><p class="text-sm mt-2"><% if (/^https?:/.test(booked.location)) { %><a href="<%= booked.location %>" class="text-secondary font-bold underline" target="_blank" rel="noopener">Join link</a><% } else { %><span class="text-on-surface-variant"><%= booked.location %></span><% } %></p><% } %>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-6">
          <a href="/interview/<%= application.interview_token %>/calendar.ics" class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-bold inline-flex items-center justify-center gap-1"><span class="material-symbols-outlined text-base">calendar_add_on</span> Add to calendar</a>
          <form action="/interview/<%= application.interview_token %>/cancel" method="post" onsubmit="return confirm('Cancel this interview? You can then pick a new time.');"><button class="border border-outline text-primary px-6 py-2.5 rounded-lg font-bold w-full">Reschedule / cancel</button></form>
        </div>
      </div>
    <% } else { %>
      <% if (!mentors.length) { %>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-8 text-center text-on-surface-variant">No interview slots are available right now. Please check back shortly or contact admissions.</div>
      <% } %>
      <div class="space-y-6">
        <% mentors.forEach(function(m){ %>
        <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-headline-sm"><%= m.name.charAt(0) %></div>
            <div><p class="font-tagline text-label-sm text-secondary uppercase">Academic Mentor</p><h3 class="font-headline text-headline-sm text-primary">Dr. <%= m.name %></h3></div>
          </div>
          <p class="font-tagline text-label-sm text-on-surface-variant uppercase mb-2">Available slots</p>
          <div class="flex flex-wrap gap-2">
            <% m.slots.forEach(function(s){ %>
            <form action="/interview/<%= application.interview_token %>/book" method="post">
              <input type="hidden" name="slot_id" value="<%= s.id %>" />
              <button class="border border-outline hover:border-secondary hover:bg-secondary-fixed text-primary px-4 py-2 rounded font-bold text-sm transition-colors"><%= formatDateTime(s.starts_at) %></button>
            </form>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
