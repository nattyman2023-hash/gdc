<%- include('../partials/page-hero', { heroTitle: 'Contact Us', heroTagline: 'We\'d Love To Hear From You', heroText: 'Questions about programmes, admissions or partnership? Get in touch.' }) %>

<section class="py-16 bg-surface-bright">
  <div class="max-w-container-max mx-auto px-margin-mobile lg:px-margin-desktop grid md:grid-cols-2 gap-12">
    <div>
      <h2 class="font-headline text-headline-md text-primary mb-6">Get in touch</h2>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-secondary text-3xl">mail</span>
          <div><p class="font-bold text-primary">Email</p><p class="text-on-surface-variant">admissions@gdcu.edu</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-secondary text-3xl">support_agent</span>
          <div><p class="font-bold text-primary">Student Helpdesk</p><p class="text-on-surface-variant">Available to current students via the student portal.</p></div>
        </div>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-secondary text-3xl">public</span>
          <div><p class="font-bold text-primary">Global &amp; Online</p><p class="text-on-surface-variant">Serving students across more than 50 nations.</p></div>
        </div>
      </div>
      <div class="bg-surface-container-low border-l-4 border-secondary rounded p-6 mt-8">
        <p class="font-headline text-headline-sm italic text-primary">"Educate. Equip. Empower. Impact the world."</p>
      </div>
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-8">
      <h2 class="font-headline text-headline-sm text-primary mb-6">Send us a message</h2>
      <form action="/contact" method="post" class="space-y-5">
        <div>
          <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Name *</label>
          <input name="name" value="<%= form.name || '' %>" class="w-full px-3 py-2 rounded border <%= errors.name ? 'border-error' : 'border-outline' %> outline-none focus:border-primary" />
          <% if (errors.name) { %><p class="text-error text-sm mt-1"><%= errors.name %></p><% } %>
        </div>
        <div>
          <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Email *</label>
          <input type="email" name="email" value="<%= form.email || '' %>" class="w-full px-3 py-2 rounded border <%= errors.email ? 'border-error' : 'border-outline' %> outline-none focus:border-primary" />
          <% if (errors.email) { %><p class="text-error text-sm mt-1"><%= errors.email %></p><% } %>
        </div>
        <div>
          <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Subject</label>
          <input name="subject" value="<%= form.subject || '' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Message *</label>
          <textarea name="message" rows="5" class="w-full px-3 py-2 rounded border <%= errors.message ? 'border-error' : 'border-outline' %> outline-none focus:border-primary"><%= form.message || '' %></textarea>
          <% if (errors.message) { %><p class="text-error text-sm mt-1"><%= errors.message %></p><% } %>
        </div>
        <button class="w-full bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90 active:scale-95 transition-all">Send Message</button>
      </form>
    </div>
  </div>
</section>
