<!-- GDCU Assistant widget -->
<div id="gdcu-chat" class="fixed bottom-5 right-5 z-50">
  <button id="chat-toggle" aria-label="Ask GDCU" class="bg-primary text-on-primary w-14 h-14 rounded-full shadow-lg flex items-center justify-center hover:scale-105 active:scale-95 transition-transform">
    <span class="material-symbols-outlined" id="chat-toggle-icon">chat</span>
  </button>

  <div id="chat-panel" class="hidden absolute bottom-16 right-0 w-[22rem] max-w-[calc(100vw-2.5rem)] bg-surface border border-outline-variant rounded-2xl shadow-2xl overflow-hidden flex flex-col" style="height:30rem">
    <div class="bg-primary text-on-primary px-4 py-3">
      <p class="font-headline text-headline-sm leading-tight">Ask GDCU</p>
      <p class="text-on-primary-container text-xs">Questions about programmes, fees, dates or applying? Ask away.</p>
    </div>
    <div id="chat-log" class="flex-1 overflow-y-auto p-4 space-y-3 text-sm bg-surface-bright">
      <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-3 text-on-surface-variant">Hi! 👋 I’m the GDCU assistant. Ask me about our programmes, tuition, open days or how to apply.</div>
    </div>
    <form id="chat-form" class="border-t border-outline-variant p-3 flex items-center gap-2 bg-surface">
      <input id="chat-input" autocomplete="off" required placeholder="Type your question…" class="flex-1 px-3 py-2 rounded-lg border border-outline outline-none focus:border-primary text-sm" />
      <button class="bg-secondary text-on-secondary w-10 h-10 rounded-lg flex items-center justify-center shrink-0"><span class="material-symbols-outlined text-base">send</span></button>
    </form>
  </div>
</div>

<script>
  (function () {
    var toggle = document.getElementById('chat-toggle');
    var icon = document.getElementById('chat-toggle-icon');
    var panel = document.getElementById('chat-panel');
    var form = document.getElementById('chat-form');
    var input = document.getElementById('chat-input');
    var log = document.getElementById('chat-log');
    if (!toggle || !panel || !form) return;

    toggle.addEventListener('click', function () {
      var open = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      icon.textContent = open ? 'chat' : 'close';
      if (!open) input.focus();
    });

    function bubble(html, who) {
      var el = document.createElement('div');
      el.className = who === 'user'
        ? 'bg-primary text-on-primary rounded-lg p-3 ml-8'
        : 'bg-surface-container-lowest border border-outline-variant rounded-lg p-3 text-on-surface';
      el.innerHTML = html;
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
      return el;
    }
    function escapeHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var q = input.value.trim();
      if (!q) return;
      bubble(escapeHtml(q), 'user');
      input.value = '';
      var thinking = bubble('<span class="text-on-surface-variant">Thinking…</span>', 'bot');
      fetch('/assistant/ask', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' }, body: JSON.stringify({ question: q }) })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var html = escapeHtml(data.answer || 'Sorry, I have no answer.').replace(/\n/g, '<br>');
          if (data.sources && data.sources.length) {
            html += '<div class="mt-2 pt-2 border-t border-outline-variant/40 text-xs text-on-surface-variant">More: ' +
              data.sources.map(function (s) { return '<a class="text-secondary font-bold" href="' + s.url + '">' + escapeHtml(s.title) + '</a>'; }).join(' · ') + '</div>';
          }
          thinking.innerHTML = html;
          log.scrollTop = log.scrollHeight;
        })
        .catch(function () { thinking.innerHTML = 'Sorry, I could not reach the assistant. Please try again or <a class="text-secondary font-bold" href="/contact">contact us</a>.'; });
    });
  })();
</script>
