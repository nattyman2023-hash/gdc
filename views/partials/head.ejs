<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>" />
<title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Global Diaspora Christian University' %></title>
<meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Global Diaspora Christian University' %>" />
<meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Global Diaspora Christian University — an online, faith-based university.' %>" />
<meta property="og:type" content="website" />
<meta property="og:url" content="<%= typeof appUrl !== 'undefined' ? appUrl : '' %>" />
<meta property="og:image" content="<%= appUrl || '' %>/img/generated/gdcu-online-learning.webp" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
<link rel="canonical" href="<%= (appUrl || '') + (currentPath || '/') %>" />
<link rel="icon" href="/img/favicon.svg" type="image/svg+xml" />
<script src="/js/theme.js"></script>
<!-- Compiled Tailwind CSS, built ahead of time from tailwind.config.js via
     `npm run build:css`. Replaces the Tailwind Play CDN (cdn.tailwindcss.com),
     which compiled all CSS in the browser on every page load and made the
     site slow. Rebuild this file whenever templates/classes change. -->
<link rel="stylesheet" href="/css/app.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>" />
<link
  href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
  rel="stylesheet"
/>
<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  .ivory-gradient { background: linear-gradient(180deg, #ffffff 0%, #fcf9f3 100%); }
  html { scroll-behavior: smooth; }
  [x-cloak] { display: none !important; }
  /* Keeps hero text crisp over photos (text-shadow is inherited by children). */
  .hero-shadow { text-shadow: 0 1px 4px rgba(7,29,58,.55), 0 1px 16px rgba(7,29,58,.35); }

  /* ── Form controls: consistent, roomy fields ───────────────── */
  .field-label { display:block; font-family:'Inter',sans-serif; font-size:12px; font-weight:600; letter-spacing:.04em;
    text-transform:uppercase; color:#44474d; margin-bottom:.35rem; }
  .field {
    display:block; width:100%; background:#ffffff; color:#1c1c18;
    border:1px solid #c4c6ce; border-radius:.5rem;
    padding:.65rem .85rem; font-size:15px; line-height:1.4;
    transition:border-color .15s, box-shadow .15s; outline:none;
  }
  textarea.field { line-height:1.6; }
  .field::placeholder { color:#9aa0a6; }
  .field:focus { border-color:#071d3a; box-shadow:0 0 0 3px rgba(7,29,58,.12); }
  .field:disabled { background:#f0eee8; color:#74777e; }
  .field-error { border-color:#ba1a1a !important; box-shadow:0 0 0 3px rgba(186,26,26,.10); }
  .field-msg { color:#ba1a1a; font-size:13px; margin-top:.3rem; }
  select.field { appearance:none; background-image:url("data:image/svg+xml;charset=US-ASCII,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='%2374777e' stroke-width='2'%3E%3Cpath d='M6 9l6 6 6-6'/%3E%3C/svg%3E");
    background-repeat:no-repeat; background-position:right .7rem center; padding-right:2.2rem; }

  /* Gentle breathing room so generic forms aren't squashed */
  form input:not([type=checkbox]):not([type=radio]):not(.field),
  form select:not(.field),
  form textarea:not(.field) { padding-top:.55rem; padding-bottom:.55rem; }

  .prose-gdcu h3 { font-family:'Playfair Display',serif; font-size:20px; font-weight:600; color:#071d3a; margin:1.25rem 0 .5rem; }
  .prose-gdcu ul { list-style:disc; padding-left:1.25rem; }
  .prose-gdcu blockquote { border-left:3px solid #b8861b; padding-left:1rem; font-style:italic; color:#44474d; }
  .animate-spin { animation: gdcu-spin 1s linear infinite; }
  @keyframes gdcu-spin { to { transform: rotate(360deg); } }
</style>
<script>
  // Add the server-issued token to static and dynamically-created browser
  // forms, including legacy admin bulk actions that call form.submit().
  (function () {
    var meta = document.querySelector('meta[name="csrf-token"]');
    var token = meta && meta.content;
    if (!token) return;
    function add(form) {
      if (!form || String(form.method || 'get').toLowerCase() !== 'post') return;
      if (!form.querySelector('input[name="_csrf"]')) {
        var input = document.createElement('input');
        input.type = 'hidden'; input.name = '_csrf'; input.value = token;
        form.appendChild(input);
      }
      // csurf cannot read a multipart body until multer has parsed it. Put a
      // copy in the query string so profile/media uploads are protected too.
      if (String(form.enctype || '').toLowerCase() === 'multipart/form-data') {
        try {
          var action = new URL(form.action || window.location.href, window.location.origin);
          action.searchParams.set('_csrf', token);
          form.action = action.toString();
        } catch (e) {}
      }
    }
    function scan(root) {
      if (!root) return;
      if (root.matches && root.matches('form')) add(root);
      if (root.querySelectorAll) root.querySelectorAll('form').forEach(add);
    }
    document.addEventListener('DOMContentLoaded', function () { scan(document); });
    document.addEventListener('submit', function (event) { add(event.target); }, true);
    if (window.MutationObserver) new MutationObserver(function (records) {
      records.forEach(function (record) { record.addedNodes.forEach(scan); });
    }).observe(document.documentElement, { childList: true, subtree: true });
    var nativeSubmit = HTMLFormElement.prototype.submit;
    HTMLFormElement.prototype.submit = function () { add(this); nativeSubmit.call(this); };
  })();
</script>
