<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  .ivory-gradient { background: linear-gradient(180deg, #ffffff 0%, #fcf9f3 100%); }
  html { scroll-behavior: smooth; }
  [x-cloak] { display: none !important; }

  /* ── Form controls: consistent, roomy fields ───────────────── */
  .field-label { display:block; font-family:'Inter',sans-serif; font-size:12px; font-weight:600; letter-spacing:.04em;
    text-transform:uppercase; color:#44474d; margin-bottom:.35rem; }
  .field {
    display:block; width:100%; background:#ffffff; color:#1c1c18;
    border:1px solid #c4c6ce; border-radius:.5rem;
    padding:.65rem .85rem; font-size:15px; line-height:1.4;
    transition:border-color .15s, box-shadow .15s; outline:none;
  }
  textarea.field { line-height:1.6; }
  .field::placeholder { color:#9aa0a6; }
  .field:focus { border-color:#071d3a; box-shadow:0 0 0 3px rgba(7,29,58,.12); }
  .field:disabled { background:#f0eee8; color:#74777e; }
  .field-error { border-color:#ba1a1a !important; box-shadow:0 0 0 3px rgba(186,26,26,.10); }
  .field-msg { color:#ba1a1a; font-size:13px; margin-top:.3rem; }
  select.field { appearance:none; background-image:url("data:image/svg+xml;charset=US-ASCII,%3Csvg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='%2374777e' stroke-width='2'%3E%3Cpath d='M6 9l6 6 6-6'/%3E%3C/svg%3E");
    background-repeat:no-repeat; background-position:right .7rem center; padding-right:2.2rem; }

  /* Gentle breathing room so generic forms aren't squashed */
  form input:not([type=checkbox]):not([type=radio]):not(.field),
  form select:not(.field),
  form textarea:not(.field) { padding-top:.55rem; padding-bottom:.55rem; }

  .prose-gdcu h3 { font-family:'Playfair Display',serif; font-size:20px; font-weight:600; color:#071d3a; margin:1.25rem 0 .5rem; }
  .prose-gdcu ul { list-style:disc; padding-left:1.25rem; }
  .prose-gdcu blockquote { border-left:3px solid #b8861b; padding-left:1rem; font-style:italic; color:#44474d; }

  /* ── Dark mode (via .dark class) ── */
  .dark body, body.dark-mode { background-color: #111318; color: #e2e2e6; }
  .dark .bg-background { background-color: #111318 !important; }
  .dark .bg-surface { background-color: #1a1c21 !important; }
  .dark .bg-surface-container-lowest { background-color: #0c0e13 !important; }
  .dark .bg-surface-container-low { background-color: #1a1c21 !important; }
  .dark .bg-surface-container { background-color: #1e2025 !important; }
  .dark .bg-surface-container-high { background-color: #282a30 !important; }
  .dark .bg-surface-container-highest { background-color: #33353b !important; }
  .dark .text-on-surface { color: #e2e2e6 !important; }
  .dark .text-on-surface-variant { color: #c2c2c8 !important; }
  .dark .text-primary { color: #aec3e8 !important; }
  .dark .text-secondary { color: #f0c04a !important; }
  .dark .border-outline-variant { border-color: #424449 !important; }
  .dark .field { background-color: #1e2025; color: #e2e2e6; border-color: #424449; }
  .dark .field:focus { border-color: #aec3e8; box-shadow: 0 0 0 3px rgba(174,195,232,.15); }
  .dark .bg-white { background-color: #1e2025 !important; }
  .dark .text-white { color: #e2e2e6 !important; }
  .dark .shadow-sm, .dark .shadow { box-shadow: 0 1px 3px 0 rgba(0,0,0,.4); }
  .animate-spin { animation: gdcu-spin 1s linear infinite; }
  @keyframes gdcu-spin { to { transform: rotate(360deg); } }
</style>
