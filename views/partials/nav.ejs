<%
  // Grouped navigation. Each group: { label, href (optional direct link), items: [[label, href]] }
  const groups = [
    { label: 'Home', href: '/' },
    { label: 'About', match: ['/about','/accreditation','/student-life','/news','/events','/alumni','/academic-calendar'], items: [
      ['About GDCU', '/about'], ['Accreditation', '/accreditation'], ['Student Life', '/student-life'],
      ['News & Insights', '/news'], ['Events', '/events'], ['Academic Calendar', '/academic-calendar'], ['Alumni Network', '/alumni'],
    ]},
    { label: 'Study', match: ['/programs','/how-it-works','/scholarships','/research-grants'], items: [
      ['All Programmes', '/programs'],
      ['Certificates', '/programs?level=Certificate'],
      ['Diplomas', '/programs?level=Diploma'],
      ['Degrees', '/programs?level=Undergraduate'],
      ['Masters', '/programs?level=Masters'],
      ['PhD / Doctorate', '/programs?level=Doctorate'],
      ['How Online Learning Works', '/how-it-works'],
      ['Scholarships & Funding', '/scholarships'], ['Research Grants', '/research-grants'],
    ]},
    { label: 'Admissions', match: ['/admissions','/faq','/open-days'], items: [
      ['Admissions & Tuition', '/admissions'], ['Apply Now', '/admissions/apply'], ['Open Days', '/open-days'], ['FAQs', '/faq'],
    ]},
    { label: 'Careers', href: '/careers' },
    { label: 'Contact', href: '/contact' },
  ];
  function isActive(g) {
    if (g.href) return g.href === '/' ? currentPath === '/' : currentPath.startsWith(g.href);
    return (g.match || []).some((p) => currentPath.startsWith(p));
  }
  const topLink = 'font-body text-sm font-semibold transition-colors';
%>
<header id="site-header" class="bg-surface-container-lowest/90 backdrop-blur-md border-b border-outline-variant fixed top-0 w-full z-50 transition-shadow">
  <nav class="flex justify-between items-center w-full px-margin-mobile lg:px-margin-desktop py-3.5 max-w-container-max mx-auto">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <img src="/img/gdcu-logo.png" alt="Global Diaspora Christian University" class="h-10 w-auto object-contain">
    </a>

    <div class="hidden lg:flex items-center gap-8">
      <% groups.forEach(function(g){ %>
        <% if (g.href) { %>
          <a href="<%= g.href %>" class="<%= topLink %> relative py-1 <%= isActive(g) ? 'text-primary' : 'text-on-surface-variant hover:text-primary' %>">
            <%= g.label %>
            <span class="absolute -bottom-0.5 left-0 h-0.5 bg-secondary transition-all duration-300 <%= isActive(g) ? 'w-full' : 'w-0' %>"></span>
          </a>
        <% } else { %>
          <div class="relative group py-1">
            <button class="<%= topLink %> inline-flex items-center gap-1 <%= isActive(g) ? 'text-primary' : 'text-on-surface-variant group-hover:text-primary' %>">
              <%= g.label %> <span class="material-symbols-outlined text-base transition-transform group-hover:rotate-180">expand_more</span>
            </button>
            <span class="absolute -bottom-0.5 left-0 h-0.5 bg-secondary transition-all duration-300 <%= isActive(g) ? 'w-[calc(100%-1.5rem)]' : 'w-0' %>"></span>
            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 hidden group-hover:block">
              <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-xl py-2 w-64 overflow-hidden">
                <% g.items.forEach(function(it){ %>
                  <a href="<%= it[1] %>" class="flex items-center gap-2 px-4 py-2.5 text-sm border-l-2 <%= currentPath===it[1] ? 'text-primary font-bold border-secondary bg-secondary-fixed/15' : 'text-on-surface-variant border-transparent hover:bg-surface-container-low hover:text-primary hover:border-secondary/50' %> transition-colors"><%= it[0] %></a>
                <% }) %>
              </div>
            </div>
          </div>
        <% } %>
      <% }) %>
    </div>

    <div class="flex items-center gap-2 shrink-0">
      <button onclick="toggleTheme()" class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant transition-colors" title="Toggle dark mode">
        <span class="material-symbols-outlined text-lg">dark_mode</span>
      </button>
      <% if (currentUser) { %>
        <a href="<%= currentUser.role==='student' ? '/portal' : (currentUser.role==='faculty' ? '/faculty' : '/admin') %>" class="hidden sm:inline font-body text-sm font-medium text-on-surface-variant hover:text-primary">My Portal</a>
        <form action="/logout" method="post"><button class="font-body text-sm font-medium text-on-surface-variant hover:text-primary">Sign out</button></form>
      <% } else { %>
        <a href="/login" class="hidden sm:inline font-body text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Student Login</a>
      <% } %>
      <a href="/admissions/apply" class="bg-secondary text-on-secondary px-5 py-2.5 rounded-lg font-body text-sm font-bold shadow-sm inline-flex items-center gap-1.5 hover:shadow-md hover:-translate-y-0.5 active:scale-95 transition-all">Apply Now <span class="material-symbols-outlined text-base">arrow_forward</span></a>
      <button id="mobile-menu-btn" class="lg:hidden text-primary" aria-label="Open menu"><span class="material-symbols-outlined text-3xl">menu</span></button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-outline-variant bg-surface-container-lowest px-margin-mobile py-4 space-y-4 max-h-[80vh] overflow-y-auto">
    <a class="block font-bold text-primary" href="/">Home</a>
    <% groups.filter(function(g){return g.items;}).forEach(function(g){ %>
      <div>
        <p class="font-tagline text-label-sm text-secondary uppercase tracking-wider mb-1"><%= g.label %></p>
        <% g.items.forEach(function(it){ %><a class="block py-1 pl-3 text-sm text-on-surface-variant" href="<%= it[1] %>"><%= it[0] %></a><% }) %>
      </div>
    <% }) %>
    <a class="block font-bold text-primary" href="/careers">Careers</a>
    <a class="block font-bold text-primary" href="/contact">Contact</a>
    <% if (!currentUser) { %><a class="block font-bold text-secondary border-t border-outline-variant pt-3" href="/login">Student Login</a><% } %>
  </div>
</header>
