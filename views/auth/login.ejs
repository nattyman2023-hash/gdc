<div class="min-h-screen grid md:grid-cols-2">
  <!-- Brand side -->
  <div class="hidden md:flex flex-col justify-between bg-primary text-on-primary p-12">
    <a href="/" class="flex items-center gap-3">
      <img src="/img/gdcu-logo.png" alt="GDCU" class="h-12 w-auto object-contain">
      <span class="font-headline text-headline-sm font-bold">Global Diaspora Christian University</span>
    </a>
    <div>
      <h1 class="font-display text-display-lg mb-4">Welcome back.</h1>
      <p class="font-body text-body-lg text-on-primary-container max-w-md">Sign in to access your courses, community and student services.</p>
    </div>
    <p class="font-tagline text-tagline text-secondary-fixed uppercase">Educate · Equip · Empower</p>
  </div>

  <!-- Form side -->
  <div class="flex items-center justify-center bg-surface-bright p-8">
    <div class="w-full max-w-md">
      <a href="/" class="md:hidden flex items-center gap-2 mb-8 text-primary">
        <img src="/img/gdcu-logo.png" alt="GDCU" class="h-10 w-auto object-contain">
        <span class="font-headline text-headline-sm font-bold">GDCU</span>
      </a>
      <h2 class="font-headline text-headline-md text-primary mb-2">Sign in</h2>
      <p class="text-on-surface-variant mb-8">Access your GDCU account.</p>

      <% if (error) { %>
        <div class="bg-error-container border-l-4 border-error text-on-error-container px-4 py-3 mb-6 rounded"><%= error %></div>
      <% } %>

      <form action="/login" method="post" class="space-y-5">
        <input type="hidden" name="next" value="<%= next %>" />
        <div>
          <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Email</label>
          <input type="email" name="email" value="<%= form.email || '' %>" required class="w-full px-3 py-3 rounded border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="block font-tagline text-label-sm text-on-surface-variant uppercase">Password</label>
            <a href="/forgot-password" class="text-secondary text-xs font-bold hover:underline">Forgot password?</a>
          </div>
          <div class="relative">
            <input id="login-password" type="password" name="password" required class="w-full px-3 py-3 pr-12 rounded border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
            <button type="button" aria-label="Show password"
              onclick="(function(b){var i=document.getElementById('login-password');var hidden=i.type==='password';i.type=hidden?'text':'password';b.querySelector('.material-symbols-outlined').textContent=hidden?'visibility_off':'visibility';b.setAttribute('aria-label',hidden?'Hide password':'Show password');})(this)"
              class="absolute right-2 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary p-1 leading-none">
              <span class="material-symbols-outlined">visibility</span>
            </button>
          </div>
        </div>
        <button class="w-full bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90 active:scale-95 transition-all">Sign In</button>
      </form>

      <p class="text-on-surface-variant text-sm mt-8 text-center">Don't have an account yet? <a href="/admissions/apply" class="text-secondary font-bold">Apply to study</a></p>
      <p class="text-center mt-4"><a href="/" class="text-on-surface-variant text-sm hover:text-primary">← Back to website</a></p>
    </div>
  </div>
</div>
