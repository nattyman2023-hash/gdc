<div class="min-h-screen grid md:grid-cols-2">
  <!-- Brand side -->
  <div class="hidden md:flex flex-col justify-between bg-primary text-on-primary p-12">
    <a href="/" class="flex items-center gap-3">
      <span class="material-symbols-outlined text-secondary-fixed-dim text-3xl" style="font-variation-settings:'FILL' 1;">school</span>
      <span class="font-headline text-headline-sm font-bold">Global Diaspora Christian University</span>
    </a>
    <div>
      <h1 class="font-display text-display-lg mb-4">Forgot your password?</h1>
      <p class="font-body text-body-lg text-on-primary-container max-w-md">No problem — we'll email you a secure link to choose a new one.</p>
    </div>
    <p class="font-tagline text-tagline text-secondary-fixed uppercase">Educate · Equip · Empower</p>
  </div>

  <!-- Form side -->
  <div class="flex items-center justify-center bg-surface-bright p-8">
    <div class="w-full max-w-md">
      <a href="/" class="md:hidden flex items-center gap-2 mb-8 text-primary"><span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">school</span><span class="font-headline text-headline-sm font-bold">GDCU</span></a>

      <% if (sent) { %>
        <span class="material-symbols-outlined text-secondary text-4xl mb-4">mark_email_read</span>
        <h2 class="font-headline text-headline-md text-primary mb-2">Check your email</h2>
        <p class="text-on-surface-variant mb-8">If an account exists for that email address, we've sent a link to reset your password. It expires in 1 hour.</p>
        <a href="/login" class="text-secondary font-bold text-sm">← Back to sign in</a>
      <% } else { %>
        <h2 class="font-headline text-headline-md text-primary mb-2">Reset your password</h2>
        <p class="text-on-surface-variant mb-8">Enter your account email and we'll send you a reset link.</p>

        <% if (error) { %>
          <div class="bg-error-container border-l-4 border-error text-on-error-container px-4 py-3 mb-6 rounded"><%= error %></div>
        <% } %>

        <form action="/forgot-password" method="post" class="space-y-5">
          <div>
            <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Email</label>
            <input type="email" name="email" required class="w-full px-3 py-3 rounded border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
          </div>
          <button class="w-full bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90 active:scale-95 transition-all">Send reset link</button>
        </form>
        <p class="text-center mt-6"><a href="/login" class="text-on-surface-variant text-sm hover:text-primary">← Back to sign in</a></p>
      <% } %>
    </div>
  </div>
</div>
