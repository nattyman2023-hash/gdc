<div class="min-h-screen grid md:grid-cols-2">
  <!-- Brand side -->
  <div class="hidden md:flex flex-col justify-between bg-primary text-on-primary p-12">
    <a href="/" class="flex items-center gap-3">
      <img src="/img/gdcu-logo.png" alt="GDCU" class="h-12 w-auto object-contain">
      <span class="font-headline text-headline-sm font-bold">Global Diaspora Christian University</span>
    </a>
    <div>
      <h1 class="font-display text-display-lg mb-4">Choose a new password.</h1>
      <p class="font-body text-body-lg text-on-primary-container max-w-md">Pick something strong you haven't used before.</p>
    </div>
    <p class="font-tagline text-tagline text-secondary-fixed uppercase">Educate · Equip · Empower</p>
  </div>

  <!-- Form side -->
  <div class="flex items-center justify-center bg-surface-bright p-8">
    <div class="w-full max-w-md">
      <a href="/" class="md:hidden flex items-center gap-2 mb-8 text-primary">
        <img src="/img/gdcu-logo.png" alt="GDCU" class="h-10 w-auto object-contain">
        <span class="font-headline text-headline-sm font-bold">GDCU</span>
      </a>

      <% if (!valid) { %>
        <span class="material-symbols-outlined text-error text-4xl mb-4">error</span>
        <h2 class="font-headline text-headline-md text-primary mb-2">Link expired</h2>
        <p class="text-on-surface-variant mb-8"><%= error || 'This password reset link is invalid or has expired.' %></p>
        <a href="/forgot-password" class="text-secondary font-bold text-sm">Request a new link →</a>
      <% } else { %>
        <h2 class="font-headline text-headline-md text-primary mb-2">Choose a new password</h2>
        <p class="text-on-surface-variant mb-8">Must be at least 8 characters.</p>

        <% if (error) { %>
          <div class="bg-error-container border-l-4 border-error text-on-error-container px-4 py-3 mb-6 rounded"><%= error %></div>
        <% } %>

        <form action="/reset-password/<%= token %>" method="post" class="space-y-5">
          <div>
            <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">New password</label>
            <input type="password" name="password" minlength="8" required class="w-full px-3 py-3 rounded border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
          </div>
          <div>
            <label class="block font-tagline text-label-sm text-on-surface-variant mb-1 uppercase">Confirm new password</label>
            <input type="password" name="password_confirm" minlength="8" required class="w-full px-3 py-3 rounded border border-outline outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
          </div>
          <button class="w-full bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90 active:scale-95 transition-all">Reset password</button>
        </form>
      <% } %>
    </div>
  </div>
</div>
