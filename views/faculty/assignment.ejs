<a href="/faculty/courses/<%= course.slug %>" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> <%= course.title %></a>

<div class="mb-6">
  <h1 class="font-headline text-headline-md text-primary"><%= assignment.title %></h1>
  <p class="text-on-surface-variant text-sm"><% if (assignment.due_date) { %>Due <%= formatDate(assignment.due_date) %> · <% } %>Out of <%= assignment.max_points %> points</p>
  <% if (assignment.instructions) { %><p class="text-on-surface-variant mt-2 whitespace-pre-line"><%= assignment.instructions %></p><% } %>
</div>

<h2 class="font-headline text-headline-sm text-primary mb-3">Submissions (<%= submissions.length %>)</h2>
<% if (!submissions.length) { %><p class="text-on-surface-variant text-sm">No submissions yet.</p><% } %>
<div class="space-y-4">
  <% submissions.forEach(function(s){ %>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <div class="flex justify-between items-start gap-3 mb-2">
      <div>
        <p class="font-bold text-primary"><%= s.first_name %> <%= s.last_name %></p>
        <p class="text-xs text-on-surface-variant">Submitted <%= formatDate(s.submitted_at) %></p>
      </div>
      <%- include('../admin/_badge', { status: s.status === 'graded' ? 'paid' : 'sent' }) %>
    </div>
    <% if (s.body) { %><p class="text-on-surface-variant text-sm whitespace-pre-line bg-surface-container-low rounded p-3 mb-2"><%= s.body %></p><% } %>
    <% if (s.url) { %><a href="<%= s.url %>" target="_blank" rel="noopener" class="text-secondary font-bold text-sm inline-flex items-center gap-1 mb-3"><span class="material-symbols-outlined text-base">attachment</span> View attachment</a><% } %>
    <form action="/faculty/submissions/<%= s.id %>/grade" method="post" class="flex flex-wrap items-end gap-3 border-t border-outline-variant/40 pt-3">
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Grade (/<%= assignment.max_points %>)</label>
        <input name="grade" type="number" min="0" max="<%= assignment.max_points %>" value="<%= s.grade != null ? s.grade : '' %>" class="w-28 px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
      </div>
      <div class="flex-1 min-w-[200px]">
        <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Feedback</label>
        <input name="feedback" value="<%= s.feedback || '' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
      </div>
      <button class="bg-secondary text-on-secondary px-5 py-2 rounded font-bold text-sm">Save grade</button>
    </form>
  </div>
  <% }) %>
</div>
