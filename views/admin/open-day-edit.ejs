<%
  function dtLocal(v){ if(!v) return ''; var d=new Date(v); if(isNaN(d)) return ''; var p=function(n){return String(n).padStart(2,'0');}; return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes()); }
  var action = isNew ? '/admin/open-days' : ('/admin/open-days/'+openDay.id+'/edit');
%>
<div class="flex items-center gap-2 mb-6">
  <a href="/admin/open-days" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm"><span class="material-symbols-outlined text-base">arrow_back</span> Open days</a>
</div>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'Schedule an open day' : 'Edit open day' %></h1>

<form action="<%= action %>" method="post" class="max-w-2xl space-y-5 bg-surface-container-lowest border border-outline-variant rounded-lg p-6">
  <div>
    <label class="field-label">Title *</label>
    <input name="title" required value="<%= openDay.title || '' %>" placeholder="e.g. June Online Open Day" class="field" />
  </div>
  <div>
    <label class="field-label">Description</label>
    <textarea name="description" rows="4" class="field" placeholder="What attendees can expect…"><%= openDay.description || '' %></textarea>
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label class="field-label">Starts *</label>
      <input type="datetime-local" name="starts_at" required value="<%= dtLocal(openDay.starts_at) %>" class="field" />
    </div>
    <div>
      <label class="field-label">Ends</label>
      <input type="datetime-local" name="ends_at" value="<%= dtLocal(openDay.ends_at) %>" class="field" />
    </div>
  </div>
  <div class="flex items-center gap-2">
    <input type="checkbox" id="is_online" name="is_online" <%= openDay.is_online ? 'checked' : '' %> />
    <label for="is_online" class="text-sm text-primary font-bold">This is an online event</label>
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label class="field-label">Location (if in person)</label>
      <input name="location" value="<%= openDay.location || '' %>" class="field" placeholder="Venue / address" />
    </div>
    <div>
      <label class="field-label">Join link (if online)</label>
      <input name="join_url" value="<%= openDay.join_url || '' %>" class="field" placeholder="https://…" />
    </div>
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div>
      <label class="field-label">Capacity (blank = unlimited)</label>
      <input type="number" min="1" name="capacity" value="<%= openDay.capacity || '' %>" class="field" />
    </div>
    <div class="flex items-end">
      <label class="flex items-center gap-2 text-sm text-primary font-bold"><input type="checkbox" name="published" <%= openDay.published ? 'checked' : '' %> /> Publish (visible on the website)</label>
    </div>
  </div>
  <div class="flex items-center gap-3 pt-2">
    <button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Create open day' : 'Save changes' %></button>
    <a href="/admin/open-days" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a>
  </div>
</form>
