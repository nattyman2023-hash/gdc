<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Admissions</p><h1 class="font-headline text-headline-md text-primary">Interviews</h1></div>

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-surface-container-high font-tagline text-label-sm uppercase text-on-surface-variant">
      <tr><th class="px-4 py-3">When</th><th class="px-4 py-3">Applicant</th><th class="px-4 py-3 hidden md:table-cell">Host</th><th class="px-4 py-3 hidden sm:table-cell">Mode</th><th class="px-4 py-3">Status</th><th class="px-4 py-3 text-right">Host</th></tr>
    </thead>
    <tbody>
      <% if (!interviews.length) { %><tr><td colspan="6" class="px-4 py-6 text-center text-on-surface-variant">No interviews scheduled.</td></tr><% } %>
      <% interviews.forEach(function(iv){ %>
      <tr class="border-t border-outline-variant/30 hover:bg-surface-container-low <%= iv.unclaimed ? 'bg-tertiary-container/30' : '' %>">
        <td class="px-4 py-3 font-bold text-primary"><a href="/admin/applications/<%= iv.application_id %>" class="hover:text-secondary"><%= formatDateTime(iv.scheduled_at) %></a></td>
        <td class="px-4 py-3 text-on-surface-variant"><%= iv.first_name %> <%= iv.last_name %> <span class="font-mono text-xs">(<%= iv.reference %>)</span></td>
        <td class="px-4 py-3 hidden md:table-cell text-on-surface-variant"><% if (iv.iv_first) { %><%= iv.iv_first %> <%= iv.iv_last %><% } else { %><span class="text-tertiary font-bold">Needs a host</span><% } %></td>
        <td class="px-4 py-3 hidden sm:table-cell text-on-surface-variant"><%= iv.mode === 'online' ? 'Online' : 'In person' %></td>
        <td class="px-4 py-3"><%- include('_badge', { status: iv.status==='completed' ? 'paid' : (iv.status==='scheduled'?'sent':'declined') }) %></td>
        <td class="px-4 py-3 text-right">
          <% if (iv.unclaimed) { %>
            <form action="/admin/interviews/<%= iv.id %>/claim" method="post"><button class="bg-secondary text-on-secondary px-3 py-1 rounded font-bold text-xs">Claim</button></form>
          <% } else { %>
            <a href="/admin/applications/<%= iv.application_id %>" class="text-secondary font-bold text-xs">Open</a>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
