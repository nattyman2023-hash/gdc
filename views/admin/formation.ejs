<div class="flex justify-between items-center mb-6 flex-wrap gap-3">
  <div><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Spiritual Life</p><h1 class="font-headline text-headline-md text-primary">Formation Groups</h1></div>
  <div class="flex items-center gap-2">
    <form action="/admin/formation/auto-assign" method="post" onsubmit="return confirm('Auto-assign all unassigned students evenly across active groups?');">
      <button class="border border-outline text-primary px-4 py-2 rounded font-bold inline-flex items-center gap-1 text-sm"><span class="material-symbols-outlined text-base">shuffle</span> Auto-assign students</button>
    </form>
    <a href="/admin/formation/new" class="bg-primary text-on-primary px-5 py-2 rounded font-bold inline-flex items-center gap-1 text-sm"><span class="material-symbols-outlined text-base">add</span> New group</a>
  </div>
</div>

<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-headline text-headline-md text-primary"><%= totalStudents %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Students</p></div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-headline text-headline-md text-primary"><%= assigned %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">In a group</p></div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-headline text-headline-md <%= unassigned ? 'text-error' : 'text-primary' %>"><%= unassigned %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Unassigned</p></div>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% if (!groups.length) { %><p class="text-on-surface-variant text-sm">No groups yet. Create one, then use <strong>Auto-assign</strong> to fill it.</p><% } %>
  <% groups.forEach(function(g){ %>
  <a href="/admin/formation/<%= g.id %>" class="block bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary transition-colors">
    <div class="flex items-center justify-between mb-1">
      <h3 class="font-headline text-headline-sm text-primary"><%= g.name %></h3>
      <%- include('_badge', { status: g.active ? 'active' : 'inactive' }) %>
    </div>
    <p class="text-on-surface-variant text-sm mb-3"><span class="material-symbols-outlined text-sm align-middle">person</span> <%= g.fac_first ? (g.fac_first+' '+g.fac_last) : 'No facilitator' %></p>
    <div class="flex items-center justify-between text-sm">
      <span class="font-bold text-primary"><%= g.members %><% if (g.capacity) { %> / <%= g.capacity %><% } %> members</span>
      <span class="text-on-surface-variant"><%= g.meeting_day %><%= g.meeting_time ? (' · '+g.meeting_time) : '' %></span>
    </div>
  </a>
  <% }) %>
</div>
