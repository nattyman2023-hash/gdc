<a href="<%= returnTo %>" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> Back</a>

<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <h1 class="font-headline text-headline-lg text-primary">Version History</h1>
    <p class="text-on-surface-variant mt-1 capitalize"><%= entityType %> #<%= entityId %> — each entry is a snapshot taken right before that change was made.</p>
  </div>

  <% if (flash.success && flash.success.length) { %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6"><p class="text-green-800"><%= flash.success[0] %></p></div>
  <% } %>
  <% if (flash.error && flash.error.length) { %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6"><p class="text-red-800"><%= flash.error[0] %></p></div>
  <% } %>

  <% if (!revisions.length) { %>
    <div class="bg-white rounded-lg shadow p-12 text-center text-on-surface-variant">
      <span class="material-symbols-outlined text-4xl mb-2">history</span>
      <p>No history yet for this item — it hasn't been edited or deleted since version history was added.</p>
    </div>
  <% } else { %>
  <div class="space-y-3">
    <% var actionStyle = { create: 'bg-green-100 text-green-800', update: 'bg-blue-100 text-blue-800', delete: 'bg-red-100 text-red-800', restore: 'bg-amber-100 text-amber-800' }; %>
    <% revisions.forEach(function(r, i){ %>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-5 py-3 flex items-center justify-between gap-3 flex-wrap">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold capitalize <%= actionStyle[r.action] || 'bg-gray-100 text-gray-800' %>"><%= r.action %></span>
          <span class="text-sm text-on-surface-variant"><%= formatDateTime(r.created_at) %> · <%= r.actorName %></span>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" onclick="document.getElementById('snap-<%= r.id %>').classList.toggle('hidden')" class="text-xs border border-outline-variant rounded px-2 py-1 hover:bg-surface-container-lowest">View snapshot</button>
          <form method="POST" action="/admin/revisions/<%= r.id %>/restore" onsubmit="return confirm('Restore this version? The current content will be overwritten.');">
            <input type="hidden" name="return_to" value="<%= returnTo %>">
            <button type="submit" class="text-xs bg-primary text-on-primary rounded px-3 py-1 font-bold hover:opacity-90">Restore this version</button>
          </form>
        </div>
      </div>
      <div id="snap-<%= r.id %>" class="hidden px-5 pb-4">
        <pre class="bg-surface-container-low rounded p-3 text-xs overflow-x-auto"><%= JSON.stringify(r.parsed, null, 2) %></pre>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
