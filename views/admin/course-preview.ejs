<div class="flex items-center justify-between mb-4">
  <a href="/admin/courses/<%= course.id %>/modules" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm"><span class="material-symbols-outlined text-base">arrow_back</span> Back to builder</a>
  <span class="inline-flex items-center gap-1 font-tagline text-label-sm uppercase text-secondary"><span class="material-symbols-outlined text-base">visibility</span> Student preview<% if (!course.published) { %> · <span class="text-error">Draft (not published)</span><% } %></span>
</div>

<!-- Hero with featured image -->
<div class="relative rounded-xl overflow-hidden mb-8 bg-primary text-on-primary">
  <img src="<%= course.featured_image || '/img/generated/gdcu-online-learning.webp' %>" alt="" class="absolute inset-0 h-full w-full object-cover" onerror="this.style.display='none'">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/70 to-primary/40"></div>
  <div class="relative p-8 md:p-12 max-w-2xl">
    <% if (course.code) { %><p class="font-tagline text-label-sm text-secondary-fixed uppercase tracking-wider mb-2"><%= course.code %></p><% } %>
    <h1 class="font-display text-display-lg-mobile md:text-display-lg leading-tight mb-3"><%= course.title %></h1>
    <% if (course.summary) { %><p class="text-on-primary-container text-body-lg mb-4"><%= course.summary %></p><% } %>
    <div class="flex flex-wrap gap-x-6 gap-y-2 text-on-primary-container text-sm">
      <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">view_module</span> <%= modules.length %> module<%= modules.length===1?'':'s' %></span>
      <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">menu_book</span> <%= lessonCount %> lesson<%= lessonCount===1?'':'s' %></span>
      <% if (totalMinutes) { %><span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">schedule</span> ~<%= Math.round(totalMinutes/60*10)/10 %> hrs</span><% } %>
      <% if (course.credits) { %><span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">workspace_premium</span> <%= course.credits %> credits</span><% } %>
      <% if (instructor) { %><span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">person</span> <%= instructor.first_name %> <%= instructor.last_name %></span><% } %>
    </div>
  </div>
</div>

<div class="grid lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2 space-y-6">
    <% if (course.description) { %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6">
      <h2 class="font-headline text-headline-sm text-primary mb-3">About this course</h2>
      <div class="prose-gdcu text-on-surface-variant text-body-md leading-relaxed"><%- course.description %></div>
    </div>
    <% } %>

    <h2 class="font-headline text-headline-sm text-primary">Course content</h2>
    <% if (!modules.length) { %><p class="text-on-surface-variant text-sm">No modules yet — add some in the builder.</p><% } %>
    <% modules.forEach(function(mod, mi){ %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden">
      <div class="px-5 py-4 bg-surface-container-low border-b border-outline-variant">
        <div class="flex items-center gap-3">
          <span class="bg-primary text-on-primary w-7 h-7 rounded-full flex items-center justify-center font-bold text-sm"><%= mi+1 %></span>
          <h3 class="font-headline text-headline-sm text-primary"><%= mod.title %></h3>
        </div>
        <% if (mod.summary) { %><p class="text-on-surface-variant text-sm mt-2"><%= mod.summary %></p><% } %>
      </div>
      <div class="divide-y divide-outline-variant/40">
        <%
          var byBlock = {}; var order = [];
          mod.lessons.forEach(function(l){ var b = l.block_no || 0; if (!byBlock[b]) { byBlock[b] = []; order.push(b); } byBlock[b].push(l); });
        %>
        <% if (!mod.lessons.length && !mod.quizzes.length) { %><div class="px-5 py-3 text-sm text-on-surface-variant">No content in this module yet.</div><% } %>
        <% order.forEach(function(b){ var ls = byBlock[b]; var bt = ls[0].block_title; %>
          <% if (b) { %>
          <div class="px-5 py-2.5 bg-indigo-50/50 flex items-center gap-2">
            <span class="material-symbols-outlined text-base text-indigo-500">view_agenda</span>
            <div><p class="font-tagline text-[11px] text-secondary uppercase leading-none">Lesson <%= b %></p><p class="font-bold text-primary text-sm"><%= bt || ('Lesson '+b) %></p></div>
          </div>
          <% } %>
          <% ls.forEach(function(l){ var part = l.type==='video' ? 'Watch (video)' : (/^Study/i.test(l.title) ? 'Scripture study' : (/^Read/i.test(l.title) ? 'Reading' : l.title)); %>
          <div class="px-5 py-2.5 flex items-center gap-3 <%= b ? 'pl-9' : '' %>">
            <span class="material-symbols-outlined text-secondary text-lg"><%= l.type==='video'?'smart_display':(l.type==='live'?'videocam':(l.type==='assignment'?'assignment':(l.type==='discussion'?'forum':(l.type==='audio'?'headphones':'menu_book')))) %></span>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-primary text-sm"><%= b ? part : l.title %></p>
              <p class="text-xs text-on-surface-variant capitalize"><%= l.type %><%= l.duration_min ? (' · ' + l.duration_min + ' min') : '' %></p>
            </div>
            <% if (l.image_url) { %><span class="material-symbols-outlined text-on-surface-variant text-base" title="Image">image</span><% } %>
          </div>
          <% }) %>
          <% var qz = mod.quizzes.find(function(q){ return q.after_block === b; }); if (qz) { %>
          <div class="px-5 py-2.5 flex items-center gap-3 bg-amber-50 <%= b ? 'pl-9' : '' %>">
            <span class="material-symbols-outlined text-amber-600 text-lg">quiz</span>
            <div class="flex-1 min-w-0"><p class="font-medium text-primary text-sm"><%= qz.title %> <span class="text-xs text-on-surface-variant font-normal">· Quiz (repeat until passed)</span></p><p class="text-xs text-on-surface-variant">Pass mark <%= qz.pass_mark %>%</p></div>
          </div>
          <% } %>
        <% }) %>
        <% mod.quizzes.filter(function(q){ return !q.after_block; }).forEach(function(qz){ %>
        <div class="px-5 py-3 flex items-center gap-3 bg-indigo-50/40">
          <span class="material-symbols-outlined text-indigo-500 text-xl">quiz</span>
          <div class="flex-1 min-w-0"><p class="font-medium text-primary text-sm"><%= qz.title %> <span class="text-xs text-on-surface-variant font-normal">· Quiz</span></p><p class="text-xs text-on-surface-variant">Pass mark <%= qz.pass_mark %>%</p></div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>

    <% if (typeof finalExam !== 'undefined' && finalExam) { %>
    <div class="bg-surface-container-lowest border-l-4 border-secondary border border-outline-variant rounded-lg p-5 flex items-center gap-3">
      <span class="material-symbols-outlined text-secondary text-2xl">workspace_premium</span>
      <div>
        <p class="font-headline text-headline-sm text-primary"><%= finalExam.title %> <span class="text-xs text-on-surface-variant font-normal">· Final Exam</span></p>
        <p class="text-xs text-on-surface-variant"><%= finalExam.questionCount %> questions · Pass mark <%= finalExam.pass_mark %>% · required for the certificate</p>
      </div>
    </div>
    <% } %>
  </div>

  <aside class="lg:col-span-1">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 sticky top-24">
      <img src="<%= course.featured_image || '/img/generated/gdcu-online-learning.webp' %>" alt="" class="w-full h-40 object-cover rounded-lg mb-4" onerror="this.style.display='none'">
      <p class="font-headline text-headline-sm text-primary mb-1"><%= course.title %></p>
      <p class="text-on-surface-variant text-sm mb-4"><%= modules.length %> modules · <%= lessonCount %> lessons</p>
      <div class="bg-secondary-container text-on-secondary-container rounded p-3 text-sm">This is a staff preview. Students enrol and study this course from their portal.</div>
    </div>
  </aside>
</div>
