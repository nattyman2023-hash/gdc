<a href="/admin/course-library" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> Module Library</a>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="font-headline text-headline-lg text-primary"><%= isNew ? 'New Shared Module' : 'Edit Shared Module' %></h1>
    <p class="text-on-surface-variant mt-1">A shared module is a reusable template (e.g. CORE-101) that can be attached to any number of courses — build it once, use it everywhere.</p>
  </div>

  <% if (flash.error && flash.error.length) { %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6"><p class="text-red-800"><%= flash.error[0] %></p></div>
  <% } %>

  <form method="POST" action="<%= isNew ? '/admin/course-library' : '/admin/course-library/' + sm.id %>" class="space-y-4 bg-white rounded-lg shadow p-6">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1">Module Code *</label>
        <input type="text" name="code" value="<%= sm.code || '' %>" required placeholder="e.g. CORE-101" class="w-full px-3 py-2 border rounded text-sm font-mono">
        <p class="text-xs text-on-surface-variant mt-1">A short, unique identifier.</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Title *</label>
        <input type="text" name="title" value="<%= sm.title || '' %>" required placeholder="e.g. Introduction to Biblical Studies" class="w-full px-3 py-2 border rounded text-sm">
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1">Year Level</label>
        <select name="year_level" class="w-full px-3 py-2 border rounded text-sm">
          <option value="1" <%= sm.year_level===1?'selected':'' %>>Year 1</option>
          <option value="2" <%= sm.year_level===2?'selected':'' %>>Year 2</option>
          <option value="3" <%= sm.year_level===3?'selected':'' %>>Year 3</option>
          <option value="4" <%= sm.year_level===4?'selected':'' %>>Year 4</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Category</label>
        <input type="text" name="category" value="<%= sm.category || '' %>" list="cat-list" placeholder="e.g. core, biblical, theology" class="w-full px-3 py-2 border rounded text-sm">
        <datalist id="cat-list">
          <% categories.forEach(function(c){ %><option value="<%= c %>"><% }) %>
        </datalist>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Featured image URL</label>
        <input type="url" name="featured_image" value="<%= sm.featured_image || '' %>" placeholder="https://…" class="w-full px-3 py-2 border rounded text-sm">
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Summary <span class="text-on-surface-variant font-normal">(shown on cards)</span></label>
      <textarea name="summary" rows="2" class="w-full px-3 py-2 border rounded text-sm"><%= sm.summary || '' %></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Description <span class="text-on-surface-variant font-normal">(longer, shown on the detail page)</span></label>
      <textarea name="description" rows="4" class="w-full px-3 py-2 border rounded text-sm"><%= sm.description || '' %></textarea>
    </div>

    <label class="flex items-center gap-2">
      <input type="checkbox" name="published" value="1" <%= sm.published ? 'checked' : '' %> class="w-4 h-4">
      <span class="text-sm font-medium">Published <span class="text-on-surface-variant font-normal">(uncheck to keep as a draft while building)</span></span>
    </label>

    <div class="flex justify-end gap-2 pt-2 border-t">
      <a href="/admin/course-library" class="px-4 py-2 border rounded text-sm">Cancel</a>
      <button type="submit" class="bg-primary text-on-primary px-6 py-2 rounded font-bold text-sm"><%= isNew ? 'Create Module' : 'Save Changes' %></button>
    </div>
  </form>
</div>