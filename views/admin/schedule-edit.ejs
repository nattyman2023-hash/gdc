<%
  function dtLocal(v){ if(!v) return ''; var d=new Date(v); if(isNaN(d.getTime())) return ''; var p=function(n){return String(n).padStart(2,'0');}; return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes()); }
  var action = isNew ? '/admin/schedule' : ('/admin/schedule/'+ev.id+'/edit');
%>
<div class="flex items-center gap-2 mb-6">
  <a href="/admin/schedule" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm"><span class="material-symbols-outlined text-base">arrow_back</span> Academic calendar</a>
</div>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New calendar entry' : 'Edit calendar entry' %></h1>

<form action="<%= action %>" method="post" class="max-w-2xl space-y-5 bg-surface-container-lowest border border-outline-variant rounded-lg p-6">
  <div><label class="field-label">Title *</label><input name="title" required value="<%= ev.title || '' %>" placeholder="e.g. University closed for Christmas" class="field" /></div>
  <div><label class="field-label">Description</label><textarea name="description" rows="3" class="field"><%= ev.description || '' %></textarea></div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div><label class="field-label">Type</label>
      <select name="category" class="field">
        <% Object.keys(cats).forEach(function(k){ %><option value="<%= k %>" <%= ev.category===k?'selected':'' %>><%= cats[k].label %></option><% }) %>
      </select>
    </div>
    <div><label class="field-label">Audience</label>
      <select name="audience" class="field">
        <% audiences.forEach(function(a){ %><option value="<%= a %>" <%= ev.audience===a?'selected':'' %>><%= a==='all' ? 'Everyone (public + portals)' : (a.charAt(0).toUpperCase()+a.slice(1)) %></option><% }) %>
      </select>
    </div>
  </div>
  <div class="grid sm:grid-cols-2 gap-4">
    <div><label class="field-label">Starts *</label><input type="datetime-local" name="starts_at" required value="<%= dtLocal(ev.starts_at) %>" class="field" /></div>
    <div><label class="field-label">Ends</label><input type="datetime-local" name="ends_at" value="<%= dtLocal(ev.ends_at) %>" class="field" /></div>
  </div>
  <div><label class="field-label">Location (optional)</label><input name="location" value="<%= ev.location || '' %>" class="field" placeholder="Online / venue" /></div>
  <div class="flex flex-wrap items-center gap-6">
    <label class="flex items-center gap-2 text-sm text-primary font-bold"><input type="checkbox" name="all_day" <%= ev.all_day ? 'checked' : '' %> /> All-day</label>
    <label class="flex items-center gap-2 text-sm text-primary font-bold"><input type="checkbox" name="published" <%= ev.published ? 'checked' : '' %> /> Published</label>
  </div>
  <div class="flex items-center gap-3 pt-2">
    <button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Create entry' : 'Save changes' %></button>
    <a href="/admin/schedule" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a>
  </div>
</form>
