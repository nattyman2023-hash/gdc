<a href="/admin/students" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All students</a>

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 mb-6 flex items-center justify-between gap-4 flex-wrap">
  <div class="flex items-center gap-4">
    <div class="w-16 h-16 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center font-headline text-headline-md"><%= student.first_name.charAt(0) %></div>
    <div>
      <h1 class="font-headline text-headline-md text-primary"><%= student.first_name %> <%= student.last_name %></h1>
      <p class="text-on-surface-variant text-sm"><%= student.email %> · joined <%= formatDate(student.created_at) %></p>
      <div class="flex items-center gap-2 mt-2">
        <% var tone = ({active:'bg-secondary-container text-on-secondary-container',warn:'bg-tertiary-container text-on-tertiary-container',warn2:'bg-tertiary-container text-on-tertiary-container',risk:'bg-error-container text-on-error-container'})[engagement.tone] || 'bg-surface-container-high text-on-surface-variant'; %>
        <span class="inline-block font-tagline text-[11px] uppercase px-2 py-1 rounded <%= tone %>"><%= engagement.label %></span>
        <% if (formationGroup) { %><a href="/admin/formation/<%= formationGroup.id %>" class="inline-block font-tagline text-[11px] uppercase px-2 py-1 rounded bg-surface-container-high text-on-surface-variant hover:text-secondary"><%= formationGroup.name %></a><% } %>
      </div>
    </div>
  </div>
  <a href="/admin/users/<%= student.id %>/edit" class="border border-outline text-primary px-4 py-2 rounded font-bold text-sm inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">edit</span> Edit account</a>
</div>

<!-- Engagement / attendance -->
<div class="grid sm:grid-cols-4 gap-4 mb-6">
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Status</p>
    <p class="font-headline text-headline-sm <%= engagement.stage>=3 ? 'text-error' : (engagement.stage>0 ? 'text-on-tertiary-container' : 'text-secondary') %>"><%= engagement.label %></p>
  </div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Last seen</p>
    <p class="font-headline text-headline-sm text-primary"><%= engagement.neverLoggedIn ? 'Never' : formatDate(student.last_login_at) %></p>
  </div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Days inactive</p>
    <p class="font-headline text-headline-sm text-primary"><%= engagement.days %></p>
  </div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <p class="font-tagline text-label-sm text-on-surface-variant uppercase">Warnings sent</p>
    <p class="font-headline text-headline-sm text-primary"><%= warnings.length %></p>
  </div>
</div>
<% if (recentLogins.length || warnings.length) { %>
<div class="grid sm:grid-cols-2 gap-4 mb-6">
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <h3 class="font-headline text-headline-sm text-primary mb-2">Recent logins</h3>
    <% if (!recentLogins.length) { %><p class="text-on-surface-variant text-sm">No logins recorded yet.</p><% } %>
    <ul class="space-y-1 text-sm text-on-surface-variant"><% recentLogins.forEach(function(l){ %><li class="flex items-center gap-2"><span class="material-symbols-outlined text-sm text-secondary">login</span> <%= formatDateTime(l.created_at) %></li><% }) %></ul>
  </div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
    <h3 class="font-headline text-headline-sm text-primary mb-2">Inactivity warnings</h3>
    <% if (!warnings.length) { %><p class="text-on-surface-variant text-sm">None sent.</p><% } %>
    <ul class="space-y-1 text-sm text-on-surface-variant"><% warnings.forEach(function(w){ %><li class="flex items-center justify-between"><span>Stage <%= w.stage %><%= w.stage===3?' — final notice':'' %></span><span class="text-[11px]"><%= formatDate(w.sent_at) %></span></li><% }) %></ul>
  </div>
</div>
<% } %>

<!-- Student profile -->
<% var sp = (typeof studentProfile !== 'undefined' && studentProfile) ? studentProfile : {}; var hasProfile = Object.keys(sp).filter(function(k){return ['phone','date_of_birth','country','nationality','address','program_id','intake','year_of_study','student_ref','emergency_name','emergency_phone','bio'].includes(k) && sp[k];}).length; %>
<div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 mb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="font-headline text-headline-sm text-primary flex items-center gap-2"><span class="material-symbols-outlined text-secondary">badge</span> Student profile</h2>
    <a href="/admin/users/<%= student.id %>/edit" class="text-secondary font-bold text-sm">Edit profile</a>
  </div>
  <% if (!hasProfile) { %>
    <p class="text-on-surface-variant text-sm">No profile details yet. <a href="/admin/users/<%= student.id %>/edit" class="text-secondary font-bold">Add them →</a></p>
  <% } else { %>
    <dl class="grid sm:grid-cols-3 gap-x-6 gap-y-3 text-sm">
      <% [
        ['Phone', sp.phone], ['Date of birth', sp.date_of_birth ? formatDate(sp.date_of_birth) : ''],
        ['Country', sp.country], ['Nationality', sp.nationality],
        ['Programme', (typeof studentProgram !== 'undefined' && studentProgram) ? studentProgram.title : ''],
        ['Intake', sp.intake], ['Year of study', sp.year_of_study], ['Student ref', sp.student_ref],
        ['Address', sp.address], ['Emergency contact', sp.emergency_name ? (sp.emergency_name + (sp.emergency_phone ? ' · ' + sp.emergency_phone : '')) : '']
      ].forEach(function(row){ if (row[1]) { %>
        <div><dt class="text-on-surface-variant text-xs uppercase font-tagline"><%= row[0] %></dt><dd class="font-bold text-primary"><%= row[1] %></dd></div>
      <% } }) %>
    </dl>
    <% if (sp.bio) { %><p class="text-on-surface-variant text-sm mt-4 pt-3 border-t border-outline-variant/40 whitespace-pre-line"><%= sp.bio %></p><% } %>
  <% } %>
</div>

<div class="grid lg:grid-cols-2 gap-6">
  <div>
    <div class="flex items-center justify-between mb-3"><h2 class="font-headline text-headline-sm text-primary">Enrolled courses</h2></div>
    <form action="/admin/students/<%= student.id %>/enroll" method="post" class="space-y-3 mb-3">
      <div class="flex gap-2">
      <select name="course_id" required class="flex-1 px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
        <option value="">Enrol in a course…</option>
        <% availableCourses.forEach(function(c){ %><option value="<%= c.id %>"><%= c.title %></option><% }) %>
      </select>
      <button class="bg-primary text-on-primary px-4 py-2 rounded font-bold text-sm whitespace-nowrap">Enrol</button>
      </div>
      <label class="flex items-start gap-2 text-xs text-on-surface-variant">
        <input type="checkbox" name="payment_waived" value="1" class="mt-0.5 rounded border-outline text-secondary focus:ring-secondary">
        <span><strong class="text-primary">Grant access without payment</strong><br>Waive the payment gate for this enrolment. An invoice will still be raised for the account.</span>
      </label>
    </form>
    <div class="space-y-3">
      <% if (!enrollments.length) { %><p class="text-on-surface-variant text-sm">No enrolments.</p><% } %>
      <% enrollments.forEach(function(e){ %>
      <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-4">
        <div class="flex justify-between items-center mb-2 gap-2"><p class="font-bold text-primary"><%= e.course_title %></p><div class="flex items-center gap-1"><%- include('_badge', { status: e.status }) %><% if (e.payment_waived) { %><span class="inline-block font-tagline text-[10px] uppercase px-2 py-1 rounded bg-secondary-fixed text-on-secondary-fixed">Access waived</span><% } %></div></div>
        <div class="w-full h-2 bg-surface-container-high rounded-full overflow-hidden"><div class="h-full bg-secondary rounded-full" style="width: <%= e.progress_pct %>%"></div></div>
        <div class="flex justify-between items-center mt-1">
          <p class="text-xs text-on-surface-variant"><%= e.progress_pct %>% complete</p>
          <div class="flex items-center gap-3">
            <% if (!e.payment_waived && ['active', 'completed'].includes(e.status)) { %>
            <form action="/admin/students/<%= student.id %>/enroll" method="post" onsubmit="return confirm('Grant this student access to ' + <%- JSON.stringify(e.course_title) %> + ' without payment? The invoice will remain on their account.');">
              <input type="hidden" name="course_id" value="<%= e.course_id %>" />
              <input type="hidden" name="payment_waived" value="1" />
              <button class="text-secondary text-xs font-bold hover:underline">Grant access without payment</button>
            </form>
            <% } %>
            <form action="/admin/students/<%= student.id %>/unenroll" method="post" onsubmit="return confirm('Remove this student from ' + <%- JSON.stringify(e.course_title) %> + '? This does not refund any invoice already raised.');">
              <input type="hidden" name="course_id" value="<%= e.course_id %>" />
              <button class="text-error text-xs font-bold hover:underline">Remove</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <h2 class="font-headline text-headline-sm text-primary mb-3 mt-6">Certificates</h2>
    <% if (!certificates.length) { %><p class="text-on-surface-variant text-sm">None issued.</p><% } %>
    <% certificates.forEach(function(c){ %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-4 mb-2 flex items-center gap-3">
      <span class="material-symbols-outlined text-secondary" style="font-variation-settings:'FILL' 1;">workspace_premium</span>
      <div><p class="font-bold text-primary text-sm"><%= c.title %></p><p class="text-xs text-on-surface-variant"><%= c.reference %> · <%= formatDate(c.issued_at) %></p></div>
    </div>
    <% }) %>
  </div>

  <div>
    <!-- Diaspora sponsorship -->
    <h2 class="font-headline text-headline-sm text-primary mb-3">Diaspora Sponsorship</h2>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 mb-6">
      <% if (sponsorship) { %>
        <p class="text-sm text-on-surface-variant mb-1">Shareable sponsor link<% if (!sponsorship.active) { %> <span class="text-error font-bold">(inactive)</span><% } %>:</p>
        <div class="flex items-center gap-2 mb-3">
          <input readonly value="<%= appUrl %>/sponsor/<%= sponsorship.token %>" class="flex-1 px-3 py-2 rounded border border-outline bg-surface-container-high text-xs" onclick="this.select()" />
          <a href="/sponsor/<%= sponsorship.token %>" target="_blank" class="material-symbols-outlined text-secondary" title="Open">open_in_new</a>
        </div>
        <div class="flex justify-between text-sm mb-2"><span class="text-on-surface-variant">Raised</span><span class="font-bold text-secondary"><%= formatMoney(raised, sponsorship.currency) %><% if (sponsorship.target_amount) { %> / <%= formatMoney(sponsorship.target_amount, sponsorship.currency) %><% } %></span></div>
        <% if (contributions.length) { %>
        <div class="border-t border-outline-variant/30 pt-2 space-y-1">
          <% contributions.forEach(function(c){ %><div class="flex justify-between text-xs"><span class="text-on-surface-variant"><%= c.sponsor_name %></span><span class="font-bold <%= c.status==='paid'?'text-secondary':'text-on-surface-variant' %>"><%= formatMoney(c.amount, sponsorship.currency) %> <%= c.status %></span></div><% }) %>
        </div>
        <% } %>
        <form action="/admin/sponsorships/<%= sponsorship.id %>/toggle" method="post" class="mt-3"><button class="text-sm font-bold <%= sponsorship.active ? 'text-error' : 'text-secondary' %>"><%= sponsorship.active ? 'Deactivate link' : 'Reactivate link' %></button></form>
      <% } else { %>
        <p class="text-sm text-on-surface-variant mb-3">Generate a shareable link so the diaspora can sponsor this student's tuition.</p>
        <form action="/admin/students/<%= student.id %>/sponsorship" method="post" class="space-y-2">
          <input name="target_amount" type="number" step="0.01" placeholder="Target amount (£, optional)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
          <input name="message" placeholder="Short appeal message (optional)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
          <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold text-sm w-full">Generate sponsorship link</button>
        </form>
      <% } %>
    </div>

    <h2 class="font-headline text-headline-sm text-primary mb-3">Tuition &amp; invoices</h2>
    <details class="bg-surface-container-lowest border border-outline-variant rounded-lg mb-4 group" open>
      <summary class="cursor-pointer px-4 py-3 font-bold text-primary list-none flex items-center gap-2"><span class="material-symbols-outlined text-secondary text-base">add_circle</span> Generate an invoice</summary>
      <form action="/admin/students/<%= student.id %>/invoices" method="post" class="px-4 pb-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="sm:col-span-2">
          <label class="block font-tagline text-[11px] text-on-surface-variant uppercase mb-1">Description *</label>
          <input name="description" required placeholder="e.g. Tuition instalment 1" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
        </div>
        <div>
          <label class="block font-tagline text-[11px] text-on-surface-variant uppercase mb-1">Amount *</label>
          <input name="amount" type="number" step="0.01" min="0.01" required class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
        </div>
        <div>
          <label class="block font-tagline text-[11px] text-on-surface-variant uppercase mb-1">Currency</label>
          <select name="currency" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm"><option>GBP</option><option>USD</option><option>EUR</option><option>KES</option></select>
        </div>
        <div>
          <label class="block font-tagline text-[11px] text-on-surface-variant uppercase mb-1">Programme</label>
          <select name="program_id" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm"><option value="">Not linked</option><% invoicePrograms.forEach(function(p){ %><option value="<%= p.id %>" <%= studentProgram && studentProgram.id === p.id ? 'selected' : '' %>><%= p.title %></option><% }) %></select>
        </div>
        <div>
          <label class="block font-tagline text-[11px] text-on-surface-variant uppercase mb-1">Due date</label>
          <input name="due_date" type="date" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
        </div>
        <button class="sm:col-span-2 bg-primary text-on-primary px-4 py-2 rounded font-bold text-sm">Create invoice draft</button>
      </form>
    </details>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden">
      <% if (!invoices.length) { %><p class="p-4 text-on-surface-variant text-sm">No invoices.</p><% } %>
      <% invoices.forEach(function(i){ %>
      <div class="flex items-center justify-between p-4 border-b border-outline-variant/30 last:border-0">
        <div><p class="font-bold text-primary text-sm"><%= i.description %></p><p class="text-xs text-on-surface-variant"><%= i.reference %> · due <%= formatDate(i.due_date) %></p></div>
        <div class="flex items-center gap-3">
          <span class="font-bold text-primary"><%= formatMoney(i.amount, i.currency) %></span>
          <%- include('_badge', { status: i.status }) %>
          <% if (i.status !== 'paid') { %>
          <form action="/admin/invoices/<%= i.id %>/pay" method="post"><button class="text-secondary font-bold text-xs underline">Mark paid</button></form>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
