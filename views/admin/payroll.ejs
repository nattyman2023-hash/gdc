<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Governance</p><h1 class="font-headline text-headline-md text-primary">Payroll</h1></div>

<div class="grid grid-cols-2 gap-4 mb-6 max-w-md">
  <div class="bg-primary text-on-primary rounded-lg p-5"><p class="font-tagline text-label-sm text-secondary-fixed uppercase">Paid</p><p class="font-display text-headline-md mt-1"><%= formatMoney(totals.paid,'GBP') %></p></div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Pending</p><p class="font-display text-headline-md text-primary mt-1"><%= formatMoney(totals.pending,'GBP') %></p></div>
</div>

<details class="bg-surface-container-lowest border <%= editing ? 'border-secondary' : 'border-outline-variant' %> rounded-lg mb-6 group" <%= editing ? 'open' : '' %>>
  <summary class="cursor-pointer px-5 py-4 font-bold text-primary list-none flex items-center gap-2"><span class="material-symbols-outlined text-secondary"><%= editing ? 'edit' : 'add_circle' %></span> <%= editing ? 'Edit payroll entry' : 'New payroll entry' %></summary>
  <form action="<%= editing ? '/admin/payroll/'+editing.id : '/admin/payroll' %>" method="post" class="p-5 pt-0 grid grid-cols-1 sm:grid-cols-5 gap-3 items-end">
    <div class="sm:col-span-2"><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Person *</label>
      <% if (editing) { %>
        <input value="<%= entries.find(function(e){return e.id===editing.id;}) ? (entries.find(function(e){return e.id===editing.id;}).first_name+' '+entries.find(function(e){return e.id===editing.id;}).last_name) : 'Staff member' %>" disabled class="w-full px-3 py-2 rounded border border-outline bg-surface-container-high text-sm" />
        <input type="hidden" name="user_id" value="<%= editing.user_id %>" />
      <% } else { %>
        <select name="user_id" required class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
          <option value="">Select…</option>
          <% staff.forEach(function(u){ %><option value="<%= u.id %>"><%= u.first_name %> <%= u.last_name %> (<%= u.role %>)</option><% }) %>
        </select>
      <% } %>
    </div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Period *</label><input name="period" required value="<%= editing ? editing.period : '' %>" placeholder="June 2026" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Gross (£) *</label><input name="gross" type="number" step="0.01" required value="<%= editing ? editing.gross : '' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Deductions (£)</label><input name="deductions" type="number" step="0.01" value="<%= editing ? editing.deductions : '0' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
    <div class="sm:col-span-5 flex gap-3"><button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= editing ? 'Save changes' : 'Add entry' %></button><% if (editing) { %><a href="/admin/payroll" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a><% } %></div>
  </form>
</details>

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-surface-container-high font-tagline text-label-sm uppercase text-on-surface-variant">
      <tr><th class="px-4 py-3">Person</th><th class="px-4 py-3">Period</th><th class="px-4 py-3 hidden sm:table-cell">Gross</th><th class="px-4 py-3 hidden sm:table-cell">Deductions</th><th class="px-4 py-3">Net</th><th class="px-4 py-3">Status</th><th class="px-4 py-3 text-right">Actions</th></tr>
    </thead>
    <tbody>
      <% if (!entries.length) { %><tr><td colspan="7" class="px-4 py-6 text-center text-on-surface-variant">No payroll entries.</td></tr><% } %>
      <% entries.forEach(function(e){ %>
      <tr class="border-t border-outline-variant/30">
        <td class="px-4 py-3 font-bold text-primary"><%= e.first_name %> <%= e.last_name %></td>
        <td class="px-4 py-3 text-on-surface-variant"><%= e.period %></td>
        <td class="px-4 py-3 hidden sm:table-cell text-on-surface-variant"><%= formatMoney(e.gross, e.currency) %></td>
        <td class="px-4 py-3 hidden sm:table-cell text-on-surface-variant"><%= formatMoney(e.deductions, e.currency) %></td>
        <td class="px-4 py-3 font-bold text-primary"><%= formatMoney(e.net, e.currency) %></td>
        <td class="px-4 py-3"><%- include('_badge', { status: e.status==='paid' ? 'paid' : 'sent' }) %></td>
        <td class="px-4 py-3 text-right whitespace-nowrap">
          <% if (e.status !== 'paid') { %><form action="/admin/payroll/<%= e.id %>/pay" method="post" class="inline"><button class="text-secondary font-bold text-xs">Mark paid</button></form><% } %>
          <a href="/admin/payroll?edit=<%= e.id %>" class="text-primary font-bold text-xs ml-2">Edit</a>
          <form action="/admin/payroll/<%= e.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete entry?');"><button class="text-error font-bold text-xs ml-2">Delete</button></form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
