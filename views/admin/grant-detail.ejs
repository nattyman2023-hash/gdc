<div class="flex justify-between items-center mb-4">
  <a href="/admin/grants" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm"><span class="material-symbols-outlined text-base">arrow_back</span> All grants</a>
  <form action="/admin/grants/<%= grant.id %>/delete" method="post" onsubmit="return confirm('Delete this application?');"><button class="inline-flex items-center gap-1 text-error border border-error/40 px-4 py-1.5 rounded font-bold text-sm"><span class="material-symbols-outlined text-base">delete</span> Delete</button></form>
</div>

<div class="grid lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 bg-surface-container-lowest border border-outline-variant rounded-lg p-6">
    <p class="font-mono text-xs text-on-surface-variant"><%= grant.reference %></p>
    <h1 class="font-headline text-headline-md text-primary mb-2"><%= grant.title %></h1>
    <div class="mb-4"><%- include('_badge', { status: grant.status==='awarded' ? 'paid' : (grant.status==='declined' ? 'declined' : (grant.status==='under_review'?'sent':'new')) }) %></div>
    <dl class="divide-y divide-outline-variant/40 text-sm mb-4">
      <div class="flex justify-between py-2"><dt class="text-on-surface-variant">Applicant</dt><dd class="font-bold text-primary"><%= grant.first_name %> <%= grant.last_name %></dd></div>
      <div class="flex justify-between py-2"><dt class="text-on-surface-variant">Email</dt><dd class="font-bold text-primary"><%= grant.email %></dd></div>
      <div class="flex justify-between py-2"><dt class="text-on-surface-variant">Institution</dt><dd class="font-bold text-primary"><%= grant.institution || '—' %></dd></div>
      <div class="flex justify-between py-2"><dt class="text-on-surface-variant">Category</dt><dd class="font-bold text-primary"><%= grant.category || '—' %></dd></div>
      <div class="flex justify-between py-2"><dt class="text-on-surface-variant">Amount requested</dt><dd class="font-bold text-primary"><%= grant.amount_requested ? formatMoney(grant.amount_requested,'GBP') : '—' %></dd></div>
    </dl>
    <h2 class="font-headline text-headline-sm text-primary mb-2">Summary</h2>
    <p class="text-on-surface-variant text-sm whitespace-pre-line"><%= grant.summary || 'No summary provided.' %></p>
  </div>

  <form action="/admin/grants/<%= grant.id %>/status" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 space-y-3 h-fit">
    <h2 class="font-headline text-headline-sm text-primary">Review</h2>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
        <% ['submitted','under_review','awarded','declined'].forEach(function(s){ %><option value="<%= s %>" <%= grant.status===s?'selected':'' %>><%= s.replace('_',' ') %></option><% }) %>
      </select>
    </div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Review notes</label><textarea name="review_notes" rows="5" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= grant.review_notes || '' %></textarea></div>
    <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold w-full">Save review</button>
    <a href="mailto:<%= grant.email %>" class="inline-flex items-center gap-1 text-secondary font-bold text-sm"><span class="material-symbols-outlined text-base">mail</span> Email applicant</a>
  </form>
</div>
