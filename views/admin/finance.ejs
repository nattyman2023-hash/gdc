<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Operations</p><h1 class="font-headline text-headline-md text-primary">Finance</h1></div>

<!-- Totals -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-primary text-on-primary rounded-lg p-5"><p class="font-tagline text-label-sm text-secondary-fixed uppercase">Collected</p><p class="font-display text-display-lg-mobile mt-1"><%= formatMoney(totals.collected, 'GBP') %></p></div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Outstanding</p><p class="font-display text-display-lg-mobile text-primary mt-1"><%= formatMoney(totals.outstanding, 'GBP') %></p></div>
  <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5"><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Overdue</p><p class="font-display text-display-lg-mobile text-error mt-1"><%= formatMoney(totals.overdue, 'GBP') %></p></div>
</div>

<!-- Create invoice -->
<details class="bg-surface-container-lowest border border-outline-variant rounded-lg mb-6 group">
  <summary class="cursor-pointer px-5 py-4 font-bold text-primary list-none flex items-center gap-2"><span class="material-symbols-outlined text-secondary">add_circle</span> Raise a new invoice</summary>
  <form action="/admin/invoices" method="post" class="p-5 pt-0 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Student *</label>
      <select name="user_id" required class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
        <option value="">Select…</option>
        <% students.forEach(function(s){ %><option value="<%= s.id %>"><%= s.first_name %> <%= s.last_name %></option><% }) %>
      </select>
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Program</label>
      <select name="program_id" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
        <option value="">—</option>
        <% programs.forEach(function(p){ %><option value="<%= p.id %>"><%= p.title %></option><% }) %>
      </select>
    </div>
    <div class="lg:col-span-2">
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Description *</label>
      <input name="description" required class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" placeholder="e.g. Tuition instalment 1 of 4" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Amount (£) *</label>
      <input name="amount" type="number" step="0.01" min="0" required class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Due date</label>
      <input name="due_date" type="date" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div class="lg:col-span-2"><button class="bg-primary text-on-primary px-6 py-2 rounded font-bold w-full sm:w-auto">Create invoice</button></div>
  </form>
</details>

<!-- Invoices table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-surface-container-high font-tagline text-label-sm uppercase text-on-surface-variant">
      <tr><th class="px-4 py-3">Ref</th><th class="px-4 py-3">Student</th><th class="px-4 py-3 hidden md:table-cell">Description</th><th class="px-4 py-3 hidden sm:table-cell">Due</th><th class="px-4 py-3">Amount</th><th class="px-4 py-3">Status</th><th class="px-4 py-3"></th></tr>
    </thead>
    <tbody>
      <% if (!invoices.length) { %><tr><td colspan="7" class="px-4 py-6 text-center text-on-surface-variant">No invoices.</td></tr><% } %>
      <% invoices.forEach(function(i){ %>
      <tr class="border-t border-outline-variant/30">
        <td class="px-4 py-3 font-mono text-xs text-on-surface-variant"><%= i.reference %></td>
        <td class="px-4 py-3 font-bold text-primary"><a href="/admin/students/<%= i.user_id %>" class="hover:text-secondary"><%= i.first_name %> <%= i.last_name %></a></td>
        <td class="px-4 py-3 hidden md:table-cell text-on-surface-variant"><%= i.description %></td>
        <td class="px-4 py-3 hidden sm:table-cell text-on-surface-variant"><%= formatDate(i.due_date) %></td>
        <td class="px-4 py-3 font-bold text-primary"><%= formatMoney(i.amount, i.currency) %></td>
        <td class="px-4 py-3"><%- include('_badge', { status: i.status }) %></td>
        <td class="px-4 py-3 text-right whitespace-nowrap">
          <% if (i.status !== 'paid') { %>
          <form action="/admin/invoices/<%= i.id %>/pay" method="post" class="inline"><button class="text-secondary font-bold text-xs">Mark paid</button></form>
          <% } %>
          <a href="/admin/invoices/<%= i.id %>/edit" class="text-primary font-bold text-xs ml-2">Edit</a>
          <form action="/admin/invoices/<%= i.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete this invoice?');"><button class="text-error font-bold text-xs ml-2">Delete</button></form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
