<%
  // Follow-up tasks block. Expects: tasks, taskEntity ('lead'|'application'),
  // taskEntityId, and optionally staff (for assignment).
  var staffList = (typeof staff !== 'undefined' && staff) ? staff : [];
  var todayStr = new Date().toISOString().slice(0,10);
%>
<div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
  <h2 class="font-headline text-headline-sm text-primary mb-3">Follow-up tasks</h2>
  <form action="/admin/<%= taskEntity %>s/<%= taskEntityId %>/tasks" method="post" class="grid grid-cols-1 sm:grid-cols-12 gap-2 mb-4">
    <input name="title" required placeholder="e.g. Call applicant about references" class="sm:col-span-6 px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
    <input name="due_date" type="date" class="sm:col-span-3 px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" />
    <% if (staffList.length) { %>
    <select name="assigned_to" class="sm:col-span-2 px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
      <option value="">Me</option>
      <% staffList.forEach(function(u){ %><option value="<%= u.id %>"><%= u.first_name %> <%= u.last_name %></option><% }) %>
    </select>
    <% } %>
    <button class="sm:col-span-1 bg-secondary text-on-secondary px-3 py-2 rounded font-bold text-sm">Add</button>
  </form>
  <div class="space-y-2">
    <% if (!tasks.length) { %><p class="text-on-surface-variant text-sm">No tasks yet.</p><% } %>
    <% tasks.forEach(function(t){ var overdue = !t.done && t.due_date && String(t.due_date).slice(0,10) < todayStr; %>
    <div class="flex items-center gap-3 py-2 border-b border-outline-variant/30 last:border-0">
      <form action="/admin/tasks/<%= t.id %>/toggle" method="post">
        <button title="Toggle complete" class="material-symbols-outlined <%= t.done ? 'text-secondary' : 'text-outline' %>" style="<%= t.done ? "font-variation-settings:'FILL' 1;" : '' %>"><%= t.done ? 'check_circle' : 'radio_button_unchecked' %></button>
      </form>
      <div class="flex-1 min-w-0">
        <p class="text-sm <%= t.done ? 'line-through text-on-surface-variant' : 'text-primary font-medium' %>"><%= t.title %></p>
        <% if (t.due_date) { %><p class="text-[11px] font-tagline uppercase <%= overdue ? 'text-error font-bold' : 'text-on-surface-variant' %>">Due <%= formatDate(t.due_date) %><%= overdue ? ' · overdue' : '' %></p><% } %>
      </div>
      <form action="/admin/tasks/<%= t.id %>/delete" method="post" onsubmit="return confirm('Delete this task?');"><button class="material-symbols-outlined text-base text-on-surface-variant hover:text-error" title="Delete task">delete</button></form>
    </div>
    <% }) %>
  </div>
</div>
