<a href="/admin/content/kb" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All articles</a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Article' : 'Edit Article' %></h1>

<form action="<%= isNew ? '/admin/content/kb' : '/admin/content/kb/'+article.id %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 max-w-3xl space-y-5">
  <% const f = (k)=> (article && article[k]!=null) ? article[k] : ''; %>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label><input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  <div class="grid sm:grid-cols-3 gap-5">
    <div class="sm:col-span-2"><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Category</label><input name="category" value="<%= f('category') %>" placeholder="Getting Started" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Sort</label><input name="sort_order" type="number" value="<%= f('sort_order')||0 %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <% if (!isNew) { %><input type="hidden" name="slug" value="<%= f('slug') %>" /><% } %>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Excerpt</label><textarea name="excerpt" rows="2" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('excerpt') %></textarea></div>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Body</label><textarea name="body" rows="10" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('body') %></textarea></div>
  <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (isNew || article.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
  <div class="flex gap-3 pt-2 border-t border-outline-variant/40"><button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Publish' : 'Save' %></button><a href="/admin/content/kb" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a></div>
</form>
