<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Content</p><h1 class="font-headline text-headline-md text-primary">Scholarships</h1></div>

<div class="grid lg:grid-cols-3 gap-6">
  <div class="lg:col-span-1">
    <form action="<%= editing ? '/admin/content/scholarships/'+editing.id : '/admin/content/scholarships' %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 space-y-3 sticky top-24">
      <h2 class="font-headline text-headline-sm text-primary"><%= editing ? 'Edit' : 'Add' %> scholarship</h2>
      <% const f = (k)=> (editing && editing[k]!=null) ? editing[k] : ''; %>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label><input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Summary</label><textarea name="summary" rows="2" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('summary') %></textarea></div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Description</label><textarea name="description" rows="3" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('description') %></textarea></div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Eligibility</label><textarea name="eligibility" rows="2" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('eligibility') %></textarea></div>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Award</label><input name="award" value="<%= f('award') %>" placeholder="Up to 50%" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Deadline</label><input name="deadline" type="date" value="<%= f('deadline') ? String(f('deadline')).slice(0,10) : '' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
      </div>
      <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (!editing || editing.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
      <div class="flex gap-2"><button class="bg-primary text-on-primary px-5 py-2 rounded font-bold"><%= editing ? 'Save' : 'Add' %></button><% if (editing) { %><a href="/admin/content/scholarships" class="px-5 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a><% } %></div>
    </form>
  </div>
  <div class="lg:col-span-2 space-y-3">
    <% if (!scholarships.length) { %><p class="text-on-surface-variant">No scholarships yet.</p><% } %>
    <% scholarships.forEach(function(s){ %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-4 flex justify-between items-start gap-3">
      <div><p class="font-bold text-primary"><%= s.title %></p><p class="text-sm text-on-surface-variant"><%= s.award || '' %><% if (s.deadline) { %> · by <%= formatDate(s.deadline) %><% } %></p></div>
      <div class="flex items-center gap-2 whitespace-nowrap">
        <% if (!s.published) { %><%- include('../_badge', { status: 'draft' }) %><% } %>
        <a href="/scholarships/<%= s.slug %>" target="_blank" class="text-on-surface-variant hover:text-primary inline-flex"><span class="material-symbols-outlined text-lg">open_in_new</span></a>
        <a href="/admin/content/scholarships?edit=<%= s.id %>" class="text-secondary font-bold text-sm">Edit</a>
        <form action="/admin/content/scholarships/<%= s.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete?');"><button class="text-error font-bold text-sm">Delete</button></form>
      </div>
    </div>
    <% }) %>
  </div>
</div>
