<a href="/admin/content/webinars" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All webinars</a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Webinar' : 'Edit Webinar' %></h1>

<%
  function dtLocal(v){ if(!v) return ''; var d=new Date(v); if(isNaN(d.getTime())) return ''; var p=function(n){return String(n).padStart(2,'0');}; return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes()); }
  const f = (k)=> (webinar && webinar[k]!=null) ? webinar[k] : '';
%>
<form action="<%= isNew ? '/admin/content/webinars' : '/admin/content/webinars/'+webinar.id %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 max-w-3xl space-y-5">
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label><input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Presenter</label><input name="presenter" value="<%= f('presenter') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Description</label><textarea name="description" rows="3" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('description') %></textarea></div>
  <div class="grid sm:grid-cols-3 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Starts *</label><input name="starts_at" type="datetime-local" required value="<%= dtLocal(f('starts_at')) %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Delivery</label><select name="provider" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><option value="external" <%= f('provider') === 'external' ? 'selected' : '' %>>External link</option><option value="zoom" <%= f('provider') === 'zoom' ? 'selected' : '' %>>Zoom meeting</option><option value="onestream" <%= f('provider') === 'onestream' ? 'selected' : '' %>>OneStream.live embed</option></select></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Join URL</label><input name="join_url" value="<%= f('join_url') %>" placeholder="https://…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Recording URL</label><input name="recording_url" value="<%= f('recording_url') %>" placeholder="https://…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">OneStream Embed URL</label><input name="stream_embed_url" value="<%= f('stream_embed_url') %>" placeholder="https://www.onestream.live/embed/..." class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div class="grid sm:grid-cols-3 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Zoom passcode</label><input name="zoom_passcode" value="<%= f('zoom_passcode') %>" placeholder="Optional" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Resource pack <span class="normal-case text-on-surface-variant/70">(one per line: Label|https://url)</span></label><textarea name="resources" rows="3" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary font-mono text-sm"><%= f('resources') %></textarea></div>
  <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (isNew || webinar.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
  <div class="flex gap-3 pt-2 border-t border-outline-variant/40"><button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Schedule' : 'Save' %></button><a href="/admin/content/webinars" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a></div>
</form>
