<a href="/admin/content/careers" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All positions</a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Position' : 'Edit Position' %></h1>

<div class="grid lg:grid-cols-3 gap-6">
  <form action="<%= isNew ? '/admin/content/careers' : '/admin/content/careers/'+job.id %>" method="post" class="lg:col-span-2 bg-surface-container-lowest border border-outline-variant rounded-lg p-6 space-y-5">
    <% const f = (k)=> (job && job[k]!=null) ? job[k] : ''; %>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label><input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div class="grid sm:grid-cols-3 gap-4">
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Type</label>
        <select name="type" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
          <% ['Faculty','Staff','Full-time','Part-time','Volunteer'].forEach(function(t){ %><option value="<%= t %>" <%= f('type')===t?'selected':'' %>><%= t %></option><% }) %>
        </select>
      </div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Department</label><input name="department" value="<%= f('department') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Location</label><input name="location" value="<%= f('location') %>" placeholder="Remote" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    </div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Summary</label><textarea name="summary" rows="2" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('summary') %></textarea></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Description</label><textarea name="description" rows="6" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('description') %></textarea></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Closes on</label><input name="closes_on" type="date" value="<%= f('closes_on') ? String(f('closes_on')).slice(0,10) : '' %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (isNew || job.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
    <div class="flex gap-3 pt-2 border-t border-outline-variant/40"><button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Publish' : 'Save' %></button><a href="/admin/content/careers" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a></div>
  </form>

  <% if (!isNew) { %>
  <div class="lg:col-span-1">
    <h2 class="font-headline text-headline-sm text-primary mb-3">Applicants (<%= applicants.length %>)</h2>
    <div class="space-y-2">
      <% if (!applicants.length) { %><p class="text-on-surface-variant text-sm">No applications yet.</p><% } %>
      <% applicants.forEach(function(a){ %>
      <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-3">
        <p class="font-bold text-primary text-sm"><%= a.first_name %> <%= a.last_name %></p>
        <p class="text-xs text-on-surface-variant"><a href="mailto:<%= a.email %>" class="hover:text-secondary"><%= a.email %></a></p>
        <% if (a.cv_url) { %><a href="<%= a.cv_url %>" target="_blank" class="text-xs text-secondary font-bold">View CV →</a><% } %>
        <% if (a.cover_note) { %><p class="text-xs text-on-surface-variant mt-1"><%= truncate(a.cover_note, 100) %></p><% } %>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>
