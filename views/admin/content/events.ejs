<div class="flex justify-between items-center mb-6 flex-wrap gap-3">
  <div><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Content</p><h1 class="font-headline text-headline-md text-primary">Events</h1></div>
  <a href="/admin/content/events/new" class="bg-primary text-on-primary px-5 py-2 rounded font-bold inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">add</span> New event</a>
</div>

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-surface-container-high font-tagline text-label-sm uppercase text-on-surface-variant">
      <tr><th class="px-4 py-3">Title</th><th class="px-4 py-3 hidden md:table-cell">Category</th><th class="px-4 py-3">When</th><th class="px-4 py-3">RSVPs</th><th class="px-4 py-3">Status</th><th class="px-4 py-3 text-right">Actions</th></tr>
    </thead>
    <tbody>
      <% if (!events.length) { %><tr><td colspan="6" class="px-4 py-6 text-center text-on-surface-variant">No events yet.</td></tr><% } %>
      <% events.forEach(function(e){ %>
      <tr class="border-t border-outline-variant/30">
        <td class="px-4 py-3 font-bold text-primary"><%= e.title %></td>
        <td class="px-4 py-3 hidden md:table-cell text-on-surface-variant"><%= e.category %></td>
        <td class="px-4 py-3 text-on-surface-variant"><%= formatDateTime(e.starts_at) %></td>
        <td class="px-4 py-3 text-on-surface-variant"><%= e.rsvps %></td>
        <td class="px-4 py-3"><%- include('../_badge', { status: e.published ? 'published' : 'draft' }) %></td>
        <td class="px-4 py-3 text-right whitespace-nowrap">
          <a href="/events/<%= e.slug %>" target="_blank" class="text-on-surface-variant hover:text-primary inline-flex" title="View live"><span class="material-symbols-outlined text-lg">open_in_new</span></a>
          <a href="/admin/content/events/<%= e.id %>/edit" class="text-secondary font-bold ml-3">Edit</a>
          <form action="/admin/content/events/<%= e.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete this event?');"><button class="text-error font-bold ml-3">Delete</button></form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
