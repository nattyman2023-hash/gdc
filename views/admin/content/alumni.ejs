<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Content</p><h1 class="font-headline text-headline-md text-primary">Alumni</h1></div>

<div class="grid lg:grid-cols-3 gap-6">
  <div class="lg:col-span-1">
    <form action="<%= editing ? '/admin/content/alumni/'+editing.id : '/admin/content/alumni' %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 space-y-3 sticky top-24">
      <h2 class="font-headline text-headline-sm text-primary"><%= editing ? 'Edit' : 'Add' %> profile</h2>
      <% const f = (k)=> (editing && editing[k]!=null) ? editing[k] : ''; %>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Name *</label><input name="name" required value="<%= f('name') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
      <div class="grid grid-cols-2 gap-2">
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Grad year</label><input name="graduation_year" type="number" value="<%= f('graduation_year') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Sort</label><input name="sort_order" type="number" value="<%= f('sort_order')||0 %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
      </div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Programme</label><input name="program" value="<%= f('program') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
      <div class="grid grid-cols-2 gap-2">
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Role</label><input name="role" value="<%= f('role') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
        <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Org</label><input name="organisation" value="<%= f('organisation') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
      </div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Country</label><input name="country" value="<%= f('country') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm" /></div>
      <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Bio</label><textarea name="bio" rows="3" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm"><%= f('bio') %></textarea></div>
      <div class="flex gap-4">
        <label class="flex items-center gap-2"><input type="checkbox" name="is_mentor" <%= editing && editing.is_mentor ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Mentor</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (!editing || editing.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
      </div>
      <div class="flex gap-2"><button class="bg-primary text-on-primary px-5 py-2 rounded font-bold"><%= editing ? 'Save' : 'Add' %></button><% if (editing) { %><a href="/admin/content/alumni" class="px-5 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a><% } %></div>
    </form>
  </div>
  <div class="lg:col-span-2 space-y-3">
    <% if (!alumni.length) { %><p class="text-on-surface-variant">No alumni profiles yet.</p><% } %>
    <% alumni.forEach(function(a){ %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-4 flex justify-between items-start gap-3">
      <div>
        <p class="font-bold text-primary"><%= a.name %> <% if (a.is_mentor) { %><span class="font-tagline text-[10px] bg-secondary text-on-secondary px-1.5 py-0.5 rounded uppercase ml-1">Mentor</span><% } %></p>
        <p class="text-sm text-on-surface-variant"><%= a.role || '' %><% if (a.organisation) { %> · <%= a.organisation %><% } %><% if (a.graduation_year) { %> · '<%= String(a.graduation_year).slice(-2) %><% } %></p>
      </div>
      <div class="flex items-center gap-2 whitespace-nowrap">
        <% if (!a.published) { %><%- include('../_badge', { status: 'draft' }) %><% } %>
        <a href="/admin/content/alumni?edit=<%= a.id %>" class="text-secondary font-bold text-sm">Edit</a>
        <form action="/admin/content/alumni/<%= a.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete?');"><button class="text-error font-bold text-sm">Delete</button></form>
      </div>
    </div>
    <% }) %>
  </div>
</div>
