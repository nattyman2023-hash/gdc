<a href="/admin/content/events" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All events</a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Event' : 'Edit Event' %></h1>

<%
  function dtLocal(v){ if(!v) return ''; var d=new Date(v); if(isNaN(d.getTime())) return ''; var p=function(n){return String(n).padStart(2,'0');}; return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes()); }
  const f = (k)=> (event && event[k]!=null) ? event[k] : '';
%>
<form action="<%= isNew ? '/admin/content/events' : '/admin/content/events/'+event.id %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 max-w-3xl space-y-5">
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label>
      <input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Category</label>
      <input name="category" value="<%= f('category') %>" placeholder="Webinar, Worship…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div>
    <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Description</label>
    <textarea name="description" rows="4" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('description') %></textarea>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Starts *</label>
      <input name="starts_at" type="datetime-local" required value="<%= dtLocal(f('starts_at')) %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Ends</label>
      <input name="ends_at" type="datetime-local" value="<%= dtLocal(f('ends_at')) %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Location</label>
      <input name="location" value="<%= f('location') %>" placeholder="London / Online" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Join URL (online)</label>
      <input name="join_url" value="<%= f('join_url') %>" placeholder="https://…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div class="flex gap-6">
    <label class="flex items-center gap-2"><input type="checkbox" name="is_online" <%= (isNew || event.is_online) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Online event</span></label>
    <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (isNew || event.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
  </div>
  <div class="flex gap-3 pt-2 border-t border-outline-variant/40">
    <button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Create event' : 'Save changes' %></button>
    <a href="/admin/content/events" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a>
  </div>
</form>
