<div class="mb-6"><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">Content</p><h1 class="font-headline text-headline-md text-primary">FAQs</h1></div>

<div class="grid lg:grid-cols-3 gap-6">
  <!-- Add / edit form -->
  <div class="lg:col-span-1">
    <form action="<%= editing ? '/admin/content/faqs/'+editing.id : '/admin/content/faqs' %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 space-y-4 sticky top-24">
      <h2 class="font-headline text-headline-sm text-primary"><%= editing ? 'Edit FAQ' : 'Add FAQ' %></h2>
      <% const f = (k)=> (editing && editing[k]!=null) ? editing[k] : ''; %>
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Category</label>
        <input name="category" value="<%= f('category') %>" placeholder="Admissions" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Question *</label>
        <input name="question" required value="<%= f('question') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Answer *</label>
        <textarea name="answer" required rows="4" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('answer') %></textarea>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex-1">
          <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Sort</label>
          <input name="sort_order" type="number" value="<%= f('sort_order')||0 %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
        </div>
        <label class="flex items-center gap-2 mt-5"><input type="checkbox" name="published" <%= (!editing || editing.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
      </div>
      <div class="flex gap-2">
        <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold"><%= editing ? 'Save' : 'Add FAQ' %></button>
        <% if (editing) { %><a href="/admin/content/faqs" class="px-5 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a><% } %>
      </div>
    </form>
  </div>

  <!-- List -->
  <div class="lg:col-span-2 space-y-3">
    <% if (!faqs.length) { %><p class="text-on-surface-variant">No FAQs yet.</p><% } %>
    <% faqs.forEach(function(q){ %>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5">
      <div class="flex justify-between items-start gap-3">
        <div>
          <span class="font-tagline text-[11px] text-secondary uppercase"><%= q.category %></span>
          <p class="font-bold text-primary"><%= q.question %></p>
        </div>
        <div class="flex items-center gap-2 whitespace-nowrap">
          <% if (!q.published) { %><%- include('../_badge', { status: 'draft' }) %><% } %>
          <a href="/admin/content/faqs?edit=<%= q.id %>" class="text-secondary font-bold text-sm">Edit</a>
          <form action="/admin/content/faqs/<%= q.id %>/delete" method="post" class="inline" onsubmit="return confirm('Delete this FAQ?');"><button class="text-error font-bold text-sm">Delete</button></form>
        </div>
      </div>
      <p class="text-on-surface-variant text-sm mt-2"><%= truncate(q.answer, 160) %></p>
    </div>
    <% }) %>
  </div>
</div>
