<a href="/admin/content/programs" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> All programs</a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Program' : 'Edit Program' %></h1>

<form action="<%= isNew ? '/admin/content/programs' : '/admin/content/programs/'+program.id %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 max-w-3xl space-y-5">
  <% const f = (k)=> (program && program[k]!=null) ? program[k] : ''; %>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Title *</label>
      <input name="title" required value="<%= f('title') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">URL slug <span class="normal-case text-on-surface-variant/70">(blank = auto)</span></label>
      <input name="slug" value="<%= f('slug') %>" placeholder="auto-generated" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div class="grid sm:grid-cols-3 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Level *</label>
      <input name="level" required value="<%= f('level') %>" placeholder="Masters, Diploma…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Credential</label>
      <input name="credential" value="<%= f('credential') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Icon <span class="normal-case text-on-surface-variant/70">(material symbol)</span></label>
      <input name="icon" value="<%= f('icon') %>" placeholder="school" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div>
    <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">School *</label>
    <input name="school" required value="<%= f('school') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
  </div>
  <div>
    <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Summary *</label>
    <textarea name="summary" required rows="2" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('summary') %></textarea>
  </div>
  <div>
    <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Full description</label>
    <textarea name="description" rows="5" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('description') %></textarea>
  </div>
  <div class="grid sm:grid-cols-3 gap-5">
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Duration</label>
      <input name="duration" value="<%= f('duration') %>" placeholder="2 years (online)" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Semester credits</label>
      <input name="semester_credits" type="number" min="0" step="1" value="<%= f('semester_credits') %>" placeholder="e.g. 120" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
      <p class="text-xs text-on-surface-variant mt-1">Use the approved curriculum total. Do not estimate.</p>
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Tuition (£)</label>
      <input name="tuition" type="number" step="0.01" value="<%= f('tuition') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Sort order</label>
      <input name="sort_order" type="number" value="<%= f('sort_order') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" />
    </div>
  </div>
  <div class="flex gap-6">
    <label class="flex items-center gap-2"><input type="checkbox" name="featured" <%= program.featured ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Featured</span></label>
    <label class="flex items-center gap-2"><input type="checkbox" name="published" <%= (isNew || program.published) ? 'checked' : '' %> class="rounded text-secondary" /> <span class="text-sm">Published</span></label>
  </div>
  <div class="flex gap-3 pt-2 border-t border-outline-variant/40">
    <button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Create program' : 'Save changes' %></button>
    <a href="/admin/content/programs" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a>
  </div>
</form>
