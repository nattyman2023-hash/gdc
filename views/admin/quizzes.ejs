<a href="/admin" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> Admin Dashboard</a>

<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <div>
      <h1 class="font-headline text-headline-lg text-primary">Quizzes Overview</h1>
      <p class="text-on-surface-variant mt-1">All module &amp; course quizzes in one place.</p>
    </div>
    <a href="/admin/courses" class="bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90">
      <span class="material-symbols-outlined align-middle mr-2">school</span>
      Go to Course Builder
    </a>
  </div>

  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 text-sm text-blue-900">
    <span class="material-symbols-outlined text-base align-middle">info</span>
    Quizzes are <strong>built inside each course</strong> (Course Builder → a module → <em>+ Quiz</em>). This page is a read-only overview. Course-wide and programme-wide <strong>final exams</strong> live under <a href="/admin/exams" class="font-bold underline">Final Exams</a>.
  </div>

  <% if (flash.success && flash.success.length) { %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6"><p class="text-green-800"><%= flash.success[0] %></p></div>
  <% } %>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-outline-variant">
      <h2 class="font-semibold text-lg">All Quizzes (<%= quizzes.length %>)</h2>
    </div>
    <div class="divide-y divide-outline-variant">
      <% quizzes.forEach(function(quiz){ %>
      <div class="p-6 hover:bg-surface-container-lowest transition-colors">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <h3 class="font-semibold text-primary mb-1"><%= quiz.title %></h3>
            <p class="text-sm text-on-surface-variant mb-2">
              Course: <%= quiz.course_title || '—' %> | Pass Mark: <%= quiz.pass_mark %>% |
              <% if (quiz.time_limit_min) { %>Time Limit: <%= quiz.time_limit_min %> min<% } else { %>No time limit<% } %>
            </p>
            <p class="text-sm text-on-surface-variant line-clamp-2"><%= quiz.description || 'No description' %></p>
          </div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 rounded-full text-xs font-medium <%= quiz.published ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
              <%= quiz.published ? 'Published' : 'Draft' %>
            </span>
            <div class="flex gap-2">
              <a href="/admin/quizzes/<%= quiz.id %>/edit" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container-lowest rounded">
                <span class="material-symbols-outlined text-base">edit</span>
              </a>
              <form method="POST" action="/admin/quizzes/<%= quiz.id %>/delete" class="inline" onsubmit="return confirm('Delete this quiz? This will remove all questions and attempts.');">
                <button type="submit" class="p-2 text-on-surface-variant hover:text-red-600 hover:bg-red-50 rounded">
                  <span class="material-symbols-outlined text-base">delete</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
