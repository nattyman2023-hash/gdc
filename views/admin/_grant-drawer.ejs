<div class="sticky top-0 bg-primary text-on-primary px-6 py-4 flex items-center justify-between z-10">
  <div>
    <p class="font-tagline text-[11px] text-secondary-fixed uppercase tracking-wider">Grant · <%= grant.reference %></p>
    <h2 class="font-headline text-headline-sm leading-tight"><%= grant.title %></h2>
  </div>
  <button data-drawer-close class="material-symbols-outlined hover:text-secondary-fixed" title="Close">close</button>
</div>

<div class="p-6 space-y-5">
  <div class="flex items-center gap-2">
    <%- include('_badge', { status: grant.status==='awarded' ? 'paid' : (grant.status==='declined' ? 'declined' : (grant.status==='under_review'?'sent':'new')) }) %>
    <a href="/admin/grants/<%= grant.id %>" class="ml-auto text-secondary font-bold text-sm inline-flex items-center gap-1">Full record <span class="material-symbols-outlined text-base">open_in_new</span></a>
  </div>

  <dl class="bg-surface-container-lowest border border-outline-variant rounded-lg divide-y divide-outline-variant/40 text-sm">
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Applicant</dt><dd class="font-bold text-primary text-right"><%= grant.first_name %> <%= grant.last_name %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Email</dt><dd class="font-bold text-primary text-right"><%= grant.email %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Institution</dt><dd class="font-bold text-primary text-right"><%= grant.institution || '—' %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Requested</dt><dd class="font-bold text-primary text-right"><%= grant.amount_requested ? formatMoney(grant.amount_requested,'GBP') : '—' %></dd></div>
  </dl>
  <% if (grant.summary) { %><div class="bg-surface-container-low rounded p-3 text-sm text-on-surface-variant whitespace-pre-line"><%= grant.summary %></div><% } %>

  <form data-drawer-form action="/admin/grants/<%= grant.id %>/status" method="post" class="space-y-2">
    <label class="field-label">Review</label>
    <select name="status" class="field">
      <% ['submitted','under_review','awarded','declined'].forEach(function(s){ %><option value="<%= s %>" <%= grant.status===s?'selected':'' %>><%= s.replace('_',' ') %></option><% }) %>
    </select>
    <textarea name="review_notes" rows="3" placeholder="Review notes" class="field"><%= grant.review_notes || '' %></textarea>
    <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold text-sm">Save review</button>
  </form>
</div>
