<a href="/admin" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> Admin Dashboard</a>

<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-headline text-headline-lg text-primary">Manage Courses</h1>
      <p class="text-on-surface-variant mt-1">Create and manage LMS courses, modules, and lessons</p>
    </div>
    <a href="/admin/courses/create" class="bg-primary text-on-primary px-6 py-3 rounded font-bold hover:opacity-90">
      <span class="material-symbols-outlined align-middle mr-2">add</span>
      Create Course
    </a>
  </div>

  <% if (flash.success && flash.success.length) { %>
    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6"><p class="text-green-800"><%= flash.success[0] %></p></div>
  <% } %>

  <div class="flex items-center justify-between mb-4">
    <h2 class="font-semibold text-lg">All Courses (<%= courses.length %>)</h2>
    <div class="inline-flex border border-outline-variant rounded overflow-hidden text-sm">
      <a href="/admin/courses?view=list" class="px-3 py-1.5 inline-flex items-center gap-1 <%= view==='list' ? 'bg-primary text-on-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-lowest' %>"><span class="material-symbols-outlined text-base">view_list</span> List</a>
      <a href="/admin/courses?view=grid" class="px-3 py-1.5 inline-flex items-center gap-1 <%= view==='grid' ? 'bg-primary text-on-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-lowest' %>"><span class="material-symbols-outlined text-base">grid_view</span> Cards</a>
    </div>
  </div>

  <% if (view === 'grid') { %>
  <!-- Card grid -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    <% courses.forEach(function(c){ %>
    <div class="group relative h-44 rounded-lg overflow-hidden border border-outline-variant shadow-sm hover:shadow-lg transition-shadow">
      <!-- Whole card opens the builder (the main place to manage a course) -->
      <a href="/admin/courses/<%= c.id %>/modules" class="absolute inset-0 z-0" title="Open course builder"></a>
      <img src="<%= c.featured_image || '/img/generated/gdcu-online-learning.png' %>" alt="" class="absolute inset-0 w-full h-full object-cover pointer-events-none" onerror="this.src='/img/generated/gdcu-online-learning.png'">
      <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/15 to-black/30 pointer-events-none"></div>
      <span class="absolute top-3 left-0 bg-primary text-on-primary text-sm font-bold px-3 py-1.5 rounded-r-md shadow max-w-[88%] leading-snug pointer-events-none"><%= c.title %></span>
      <% if (!c.published) { %><span class="absolute top-3 right-3 bg-gray-200 text-gray-800 text-[10px] font-bold px-2 py-0.5 rounded-full pointer-events-none">Draft</span><% } %>
      <div class="absolute bottom-2 left-3 text-white text-xs pointer-events-none"><%= c.moduleCount %> modules · <%= c.enrollmentCount %> enrolled</div>
      <div class="absolute bottom-2 right-3 flex items-center gap-1 z-10">
        <a href="/admin/courses/<%= c.id %>/preview" target="_blank" class="bg-white/95 text-primary p-1.5 rounded-full hover:bg-white" title="Preview as a student"><span class="material-symbols-outlined text-sm align-middle">visibility</span></a>
        <a href="/admin/courses/<%= c.id %>/modules" class="bg-white/95 text-primary text-xs font-bold px-3 py-1.5 rounded-full inline-flex items-center gap-1 hover:bg-white">Build <span class="material-symbols-outlined text-sm">arrow_forward</span></a>
      </div>
    </div>
    <% }) %>
  </div>
  <% if (courses.length === 0) { %><p class="text-on-surface-variant text-center mt-6">No courses yet.</p><% } %>
  <% } else { %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="divide-y divide-outline-variant">
      <% courses.forEach(function(c){ %>
      <div class="p-6 hover:bg-surface-container-lowest transition-colors">
        <div class="flex items-center justify-between gap-4">
          <div class="w-24 h-16 shrink-0 rounded-lg overflow-hidden bg-surface-container-high border border-outline-variant">
            <img src="<%= c.featured_image || '/img/generated/gdcu-online-learning.png' %>" alt="" class="w-full h-full object-cover" onerror="this.src='/img/generated/gdcu-online-learning.png'">
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-1">
              <h3 class="font-semibold text-primary"><%= c.title %></h3>
              <% if (c.code) { %><span class="text-xs bg-surface-container-high px-2 py-0.5 rounded"><%= c.code %></span><% } %>
              <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= c.published ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                <%= c.published ? 'Published' : 'Draft' %>
              </span>
              <% if (c.drip_feed_enabled) { %>
                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Drip Feed</span>
              <% } %>
            </div>
            <p class="text-sm text-on-surface-variant mb-2"><%= c.summary || 'No summary' %></p>
            <div class="flex gap-4 text-xs text-on-surface-variant">
              <span><span class="material-symbols-outlined text-sm align-middle">folder</span> <%= c.moduleCount %> modules</span>
              <span><span class="material-symbols-outlined text-sm align-middle">group</span> <%= c.enrollmentCount %> enrolled</span>
              <span><span class="material-symbols-outlined text-sm align-middle">school</span> <%= c.credits %> credits</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <a href="/admin/courses/<%= c.id %>/preview" target="_blank" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container-lowest rounded" title="Preview">
              <span class="material-symbols-outlined text-base">visibility</span>
            </a>
            <a href="/admin/courses/<%= c.id %>/modules" class="px-4 py-2 bg-primary text-on-primary rounded text-sm font-medium hover:opacity-90">
              <span class="material-symbols-outlined text-sm align-middle mr-1">list_alt</span> Modules
            </a>
            <a href="/admin/courses/<%= c.id %>/edit" class="p-2 text-on-surface-variant hover:text-primary hover:bg-surface-container-lowest rounded">
              <span class="material-symbols-outlined text-base">edit</span>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
      <% if (courses.length === 0) { %>
        <div class="p-12 text-center text-on-surface-variant">
          <span class="material-symbols-outlined text-4xl mb-2">school</span>
          <p>No courses yet. Create your first course to get started.</p>
        </div>
      <% } %>
    </div>
  </div>
  <% } %>
</div>