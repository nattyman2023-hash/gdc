<div class="flex justify-between items-center mb-4">
  <a href="/admin/support" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm"><span class="material-symbols-outlined text-base">arrow_back</span> All tickets</a>
  <div class="flex items-center gap-2">
    <% if (ticket.status === 'closed') { %>
      <form action="/admin/support/<%= ticket.id %>/reopen" method="post"><button class="inline-flex items-center gap-1 border border-outline text-primary px-4 py-1.5 rounded font-bold text-sm"><span class="material-symbols-outlined text-base">lock_open</span> Reopen</button></form>
    <% } else { %>
      <form action="/admin/support/<%= ticket.id %>/close" method="post"><button class="inline-flex items-center gap-1 border border-outline text-primary px-4 py-1.5 rounded font-bold text-sm"><span class="material-symbols-outlined text-base">check_circle</span> Close ticket</button></form>
    <% } %>
    <form action="/admin/support/<%= ticket.id %>/delete" method="post" onsubmit="return confirm('Delete this ticket?');"><button class="inline-flex items-center gap-1 text-error border border-error/40 px-4 py-1.5 rounded font-bold text-sm"><span class="material-symbols-outlined text-base">delete</span> Delete</button></form>
  </div>
</div>

<div class="max-w-3xl">
  <div class="flex justify-between items-start gap-3 mb-4">
    <div>
      <h1 class="font-headline text-headline-sm text-primary"><%= ticket.subject %></h1>
      <p class="text-xs text-on-surface-variant"><%= ticket.reference %> · <%= ticket.category %> · from <%= ticket.first_name ? (ticket.first_name+' '+ticket.last_name) : (ticket.email||'guest') %></p>
    </div>
    <%- include('_badge', { status: (ticket.status==='resolved'||ticket.status==='closed') ? 'paid' : (ticket.status==='pending'?'sent':'new') }) %>
  </div>

  <div id="ticket-thread" class="space-y-3 mb-6 rounded-lg transition-shadow">
    <% replies.forEach(function(r){ %>
    <div class="rounded-lg p-4 <%= r.is_staff ? 'bg-secondary-fixed/40 border border-secondary/40 ml-6' : 'bg-surface-container-lowest border border-outline-variant mr-6' %>">
      <div class="flex justify-between items-center mb-1">
        <p class="font-bold text-primary text-sm"><%= r.author_name || (r.is_staff?'Staff':'Student') %><% if (r.is_staff) { %> <span class="font-tagline text-[10px] bg-secondary text-on-secondary px-1.5 py-0.5 rounded uppercase">Staff</span><% } %></p>
        <p class="text-[11px] text-on-surface-variant"><%= formatDate(r.created_at) %><% if (r.edited_at) { %> · edited<% } %><% if (r.author_id === currentUser.id && editReply !== r.id) { %> · <a href="/admin/support/<%= ticket.id %>?editReply=<%= r.id %>" class="text-secondary font-bold">Edit</a><% } %></p>
      </div>
      <% if (editReply === r.id) { %>
        <form action="/admin/ticket-replies/<%= r.id %>" method="post" class="space-y-2">
          <textarea name="body" rows="3" class="field"><%= r.body %></textarea>
          <div class="flex gap-2"><button class="bg-primary text-on-primary px-4 py-1.5 rounded font-bold text-sm">Save</button><a href="/admin/support/<%= ticket.id %>" class="px-4 py-1.5 rounded font-bold text-sm border border-outline text-on-surface-variant">Cancel</a></div>
        </form>
      <% } else { %>
        <p class="text-on-surface text-sm whitespace-pre-line"><%= r.body %></p>
      <% } %>
    </div>
    <% }) %>
  </div>

  <form action="/admin/support/<%= ticket.id %>/reply" method="post" data-async-refresh="#ticket-thread" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-4 space-y-3">
    <textarea name="body" rows="3" placeholder="Reply to the student…" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"></textarea>
    <div class="flex items-center justify-between gap-3">
      <select name="status" class="px-3 py-2 rounded border border-outline outline-none focus:border-primary text-sm">
        <% ['open','pending','resolved','closed'].forEach(function(s){ %><option value="<%= s %>" <%= ticket.status===s?'selected':'' %>>Set: <%= s %></option><% }) %>
      </select>
      <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold">Send &amp; update</button>
    </div>
  </form>
</div>
