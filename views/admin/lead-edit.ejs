<% var isNew = typeof isNew !== 'undefined' ? isNew : false; %>
<a href="<%= isNew ? '/admin/leads' : '/admin/leads/'+lead.id %>" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-primary text-sm mb-4"><span class="material-symbols-outlined text-base">arrow_back</span> <%= isNew ? 'All leads' : 'Back to lead' %></a>
<h1 class="font-headline text-headline-md text-primary mb-6"><%= isNew ? 'New Lead' : 'Edit Lead' %></h1>

<form action="<%= isNew ? '/admin/leads' : '/admin/leads/'+lead.id+'/edit' %>" method="post" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-6 max-w-2xl space-y-5">
  <% const f = (k)=> (lead && lead[k]!=null) ? lead[k] : ''; %>
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">First name *</label><input name="first_name" required value="<%= f('first_name') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Last name</label><input name="last_name" value="<%= f('last_name') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Email *</label><input type="email" name="email" required value="<%= f('email') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Phone</label><input name="phone" value="<%= f('phone') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Country</label><input name="country" value="<%= f('country') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Program of interest</label>
      <select name="program_id" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
        <option value="">—</option>
        <% programs.forEach(function(p){ %><option value="<%= p.id %>" <%= String(f('program_id'))===String(p.id)?'selected':'' %>><%= p.title %></option><% }) %>
      </select>
    </div>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary">
        <% statuses.forEach(function(s){ %><option value="<%= s %>" <%= f('status')===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
    </div>
    <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Interest (free text)</label><input name="interest" value="<%= f('interest') %>" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary" /></div>
  </div>
  <div><label class="block font-tagline text-label-sm text-on-surface-variant uppercase mb-1">Message</label><textarea name="message" rows="3" class="w-full px-3 py-2 rounded border border-outline outline-none focus:border-primary"><%= f('message') %></textarea></div>
  <div class="flex gap-3 pt-2 border-t border-outline-variant/40">
    <button class="bg-primary text-on-primary px-6 py-2 rounded font-bold"><%= isNew ? 'Create lead' : 'Save changes' %></button>
    <a href="<%= isNew ? '/admin/leads' : '/admin/leads/'+lead.id %>" class="px-6 py-2 rounded font-bold border border-outline text-on-surface-variant">Cancel</a>
  </div>
</form>
