<%
  function toneClasses(tone){
    return ({
      active: 'bg-secondary-container text-on-secondary-container',
      warn:   'bg-tertiary-container text-on-tertiary-container',
      warn2:  'bg-tertiary-container text-on-tertiary-container',
      risk:   'bg-error-container text-on-error-container',
    })[tone] || 'bg-surface-container-high text-on-surface-variant';
  }
%>
<div class="flex justify-between items-center mb-6 flex-wrap gap-3">
  <div><p class="font-tagline text-label-sm text-secondary uppercase tracking-widest">People</p><h1 class="font-headline text-headline-md text-primary">Attendance &amp; Engagement</h1><p class="text-on-surface-variant mt-1 text-sm">Live view from each student’s last login. Logging in resets their status automatically.</p></div>
  <form action="/admin/attendance/run" method="post" onsubmit="return confirm('Send escalating warning emails now to students who are due one?');">
    <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold inline-flex items-center gap-1 text-sm"><span class="material-symbols-outlined text-base">outgoing_mail</span> Run warnings now</button>
  </form>
</div>

<!-- Summary cards (each links to a filtered view) -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <a href="/admin/attendance?stage=0" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary"><p class="font-headline text-headline-md text-primary"><%= counts.active %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Active</p></a>
  <a href="/admin/attendance?stage=1" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary"><p class="font-headline text-headline-md text-on-tertiary-container"><%= counts[1] %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Inactive 1 week</p></a>
  <a href="/admin/attendance?stage=2" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary"><p class="font-headline text-headline-md text-on-tertiary-container"><%= counts[2] %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">Inactive 2 weeks</p></a>
  <a href="/admin/attendance?stage=3" class="bg-surface-container-lowest border border-outline-variant rounded-lg p-5 hover:border-secondary"><p class="font-headline text-headline-md text-error"><%= counts[3] %></p><p class="font-tagline text-label-sm text-on-surface-variant uppercase">At risk (3+ wks)</p></a>
</div>

<form method="get" class="flex flex-wrap gap-3 mb-5">
  <input name="q" value="<%= filters.q %>" placeholder="Search student…" class="px-3 py-2 rounded border border-outline outline-none focus:border-primary min-w-[200px]" />
  <select name="stage" class="px-3 py-2 rounded border border-outline outline-none focus:border-primary">
    <option value="">All statuses</option>
    <option value="0" <%= filters.stage==='0'?'selected':'' %>>Active</option>
    <option value="1" <%= filters.stage==='1'?'selected':'' %>>Inactive 1 week</option>
    <option value="2" <%= filters.stage==='2'?'selected':'' %>>Inactive 2 weeks</option>
    <option value="3" <%= filters.stage==='3'?'selected':'' %>>At risk (3+ weeks)</option>
  </select>
  <button class="bg-primary text-on-primary px-5 py-2 rounded font-bold">Filter</button>
  <a href="/admin/attendance" class="px-5 py-2 rounded font-bold border border-outline text-on-surface-variant">Reset</a>
</form>

<div class="bg-surface-container-lowest border border-outline-variant rounded-lg overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-surface-container-high font-tagline text-label-sm uppercase text-on-surface-variant">
      <tr><th class="px-4 py-3">Student</th><th class="px-4 py-3 hidden sm:table-cell">Last seen</th><th class="px-4 py-3">Inactive</th><th class="px-4 py-3">Status</th><th class="px-4 py-3 text-right">View</th></tr>
    </thead>
    <tbody>
      <% if (!rows.length) { %><tr><td colspan="5" class="px-4 py-6 text-center text-on-surface-variant">No students match.</td></tr><% } %>
      <% rows.forEach(function(r){ %>
      <tr class="border-t border-outline-variant/30 hover:bg-surface-container-low">
        <td class="px-4 py-3"><a href="/admin/students/<%= r.id %>" class="font-bold text-primary hover:text-secondary"><%= r.name %></a><br/><span class="text-[11px] text-on-surface-variant"><%= r.email %></span></td>
        <td class="px-4 py-3 hidden sm:table-cell text-on-surface-variant"><%= r.neverLoggedIn ? 'Never logged in' : formatDate(r.last_login_at) %></td>
        <td class="px-4 py-3 text-on-surface-variant"><%= r.days %> day<%= r.days===1?'':'s' %></td>
        <td class="px-4 py-3"><span class="inline-block font-tagline text-[11px] uppercase px-2 py-1 rounded <%= toneClasses(r.tone) %>"><%= r.label %></span></td>
        <td class="px-4 py-3 text-right"><a href="/admin/students/<%= r.id %>" class="text-secondary font-bold">Open</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% if (recentWarnings.length) { %>
<h2 class="font-headline text-headline-sm text-primary mt-8 mb-3">Recent warning emails</h2>
<div class="bg-surface-container-lowest border border-outline-variant rounded-lg divide-y divide-outline-variant/40">
  <% recentWarnings.forEach(function(w){ %>
  <div class="flex items-center justify-between p-3 text-sm">
    <span class="text-primary font-bold"><%= w.first_name %> <%= w.last_name || '' %></span>
    <span class="text-on-surface-variant">Stage <%= w.stage %> <%= w.stage===3?'(final notice)':'' %> · <%= formatDate(w.sent_at) %></span>
  </div>
  <% }) %>
</div>
<% } %>
