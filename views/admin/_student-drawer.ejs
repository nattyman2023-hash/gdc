<div class="sticky top-0 bg-primary text-on-primary px-6 py-4 flex items-center justify-between z-10">
  <div>
    <p class="font-tagline text-[11px] text-secondary-fixed uppercase tracking-wider">Student</p>
    <h2 class="font-headline text-headline-sm leading-tight"><%= student.first_name %> <%= student.last_name %></h2>
  </div>
  <button data-drawer-close class="material-symbols-outlined hover:text-secondary-fixed" title="Close">close</button>
</div>

<div class="p-6 space-y-5">
  <div class="flex items-center gap-2">
    <%- include('_badge', { status: student.status === 'active' ? 'paid' : 'void' }) %>
    <a href="/admin/students/<%= student.id %>" class="ml-auto text-secondary font-bold text-sm inline-flex items-center gap-1">Full record <span class="material-symbols-outlined text-base">open_in_new</span></a>
  </div>

  <dl class="bg-surface-container-lowest border border-outline-variant rounded-lg divide-y divide-outline-variant/40 text-sm">
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Email</dt><dd class="font-bold text-primary text-right"><%= student.email %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Joined</dt><dd class="font-bold text-primary text-right"><%= formatDate(student.created_at) %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Certificates</dt><dd class="font-bold text-primary text-right"><%= certificates %></dd></div>
    <div class="flex justify-between px-4 py-2"><dt class="text-on-surface-variant">Outstanding</dt><dd class="font-bold <%= outstanding>0?'text-error':'text-secondary' %> text-right"><%= formatMoney(outstanding, 'GBP') %></dd></div>
  </dl>

  <div>
    <h3 class="font-headline text-headline-sm text-primary mb-2">Enrolled courses</h3>
    <div class="space-y-2">
      <% if (!enrollments.length) { %><p class="text-on-surface-variant text-sm">No enrolments.</p><% } %>
      <% enrollments.forEach(function(e){ %>
      <div class="bg-surface-container-lowest border border-outline-variant rounded-lg p-3">
        <div class="flex justify-between items-center mb-1"><p class="font-bold text-primary text-sm"><%= e.course_title %></p><span class="text-xs text-on-surface-variant"><%= e.progress_pct %>%</span></div>
        <div class="w-full h-1.5 bg-surface-container-high rounded-full overflow-hidden"><div class="h-full bg-secondary rounded-full" style="width: <%= e.progress_pct %>%"></div></div>
      </div>
      <% }) %>
    </div>
  </div>

  <a href="/admin/students/<%= student.id %>" class="block text-center bg-primary text-on-primary px-5 py-2.5 rounded font-bold">Open full record</a>
</div>
