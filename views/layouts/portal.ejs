<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-surface-container-low text-on-surface font-body text-body-md min-h-screen">
<div class="flex min-h-screen">
  <!-- Sidebar -->
  <aside id="portal-sidebar" class="fixed lg:static inset-y-0 left-0 z-40 w-64 bg-primary text-on-primary flex-col -translate-x-full lg:translate-x-0 transition-transform flex">
    <div class="px-6 py-5 border-b border-on-primary-fixed-variant/30">
      <a href="/portal" class="flex items-center gap-3">
        <img src="/img/gdcu-logo.png" alt="GDCU" class="h-10 w-auto object-contain">
        <span class="font-headline text-headline-sm font-bold leading-tight">GDCU<br/><span class="font-tagline text-label-sm text-secondary-fixed uppercase">Student Portal</span></span>
      </a>
    </div>
    <nav class="flex-1 py-3 space-y-0.5 overflow-y-auto">
      <% const groups = [
        ['', [['dashboard','/portal','Dashboard','dashboard']]],
        ['Learning', [
          ['courses','/portal/catalog','Course Catalogue','menu_book'],
          ['library','/portal/library','Library','local_library'],
          ['performance','/portal/performance','My Performance','analytics'],
          ['exams','/portal/exams','Final Exams','workspace_premium'],
          ['transcript','/portal/transcript','Transcript','receipt_long']
        ]],
        ['Community', [
          ['chat','/portal/chat','Chat','chat'],
          ['schedule','/portal/schedule','Schedule & Dates','date_range'],
          ['events','/portal/events','Events','event'],
          ['webinars','/portal/webinars','Live Webinars','podcasts'],
          ['mentorship','/portal/mentorship','Mentorship','handshake']
        ]],
        ['Milestones', [
          ['certificates','/portal/certificates','Certificates','workspace_premium'],
          ['graduation','/portal/graduation','Graduation','school']
        ]],
        ['Account', [
          ['billing','/portal/billing','Billing & Payments','payments'],
          ['support','/portal/support','Support','support_agent'],
          ['profile','/portal/profile','My Profile','person']
        ]]
      ]; %>
      <% groups.forEach(function(g){ %>
        <% if (g[0]) { %><p class="px-6 pt-3 pb-1 font-tagline text-[11px] text-secondary-fixed uppercase tracking-wider"><%= g[0] %></p><% } %>
        <% g[1].forEach(function(it){ %>
        <%
          // Highlight when the page sends a matching key OR (self-correcting) the
          // current URL matches this item's path. Dashboard ('/portal') matches
          // only its exact path so it doesn't light up on every sub-page.
          var p = (typeof currentPath !== 'undefined' && currentPath) || '';
          var isActive = (typeof portalActive !== 'undefined' && portalActive === it[0])
            || (it[1] === '/portal' ? p === '/portal' : (p === it[1] || p.indexOf(it[1] + '/') === 0));
        %>
        <a href="<%= it[1] %>" class="flex items-center gap-3 px-6 py-2.5 font-body text-body-md <%= isActive ? 'bg-on-primary-fixed-variant/30 border-l-4 border-secondary text-on-primary font-bold' : 'text-on-primary-container hover:bg-on-primary-fixed-variant/20' %>">
          <span class="material-symbols-outlined text-xl"><%= it[3] %></span><%= it[2] %>
        </a>
        <% }) %>
      <% }) %>
    </nav>
  </aside>

  <!-- Main -->
  <div class="flex-1 flex flex-col min-w-0">
    <%- include('../partials/preview-banner') %>
    <header class="bg-surface-container-lowest border-b border-outline-variant px-6 py-4 flex items-center justify-between sticky top-0 z-30">
      <button id="portal-menu-btn" class="lg:hidden text-primary" aria-label="Menu"><span class="material-symbols-outlined">menu</span></button>
      <div class="flex-1"></div>
      <div class="flex items-center gap-4">
        <a href="/" class="hidden sm:flex items-center gap-1 text-xs text-on-surface-variant hover:text-primary"><span class="material-symbols-outlined text-sm">public</span> Main website</a>
        <form action="/logout" method="post" class="hidden sm:block"><button class="flex items-center gap-1 text-xs text-on-surface-variant hover:text-error"><span class="material-symbols-outlined text-sm">logout</span> Sign out</button></form>
        <%- include('../partials/bell') %>
        <div class="w-9 h-9 rounded-full bg-secondary-container text-on-secondary-container flex items-center justify-center font-bold"><%= (currentUser.name||'S').charAt(0) %></div>
        <span class="hidden sm:inline font-bold text-primary text-sm"><%= currentUser.name %></span>
      </div>
    </header>

    <main class="flex-1 p-6 lg:p-8 max-w-6xl w-full mx-auto">
      <% if (flash.success.length || flash.error.length || flash.info.length) { %>
        <%- include('../partials/flash') %>
      <% } %>
      <%- body %>
    </main>
  </div>
</div>
<div id="portal-overlay" class="fixed inset-0 bg-black/40 z-30 hidden lg:hidden"></div>
<script>
  (function(){
    var btn=document.getElementById('portal-menu-btn'), sb=document.getElementById('portal-sidebar'), ov=document.getElementById('portal-overlay');
    function open(){sb.classList.remove('-translate-x-full');ov.classList.remove('hidden');}
    function close(){sb.classList.add('-translate-x-full');ov.classList.add('hidden');}
    if(btn) btn.addEventListener('click',open);
    if(ov) ov.addEventListener('click',close);
  })();
</script>
</body>
</html>
