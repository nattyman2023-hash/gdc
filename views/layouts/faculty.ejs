<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-surface-container-low text-on-surface font-body text-body-md min-h-screen">
<div class="flex min-h-screen">
  <aside id="fac-sidebar" class="fixed lg:static inset-y-0 left-0 z-40 w-64 bg-primary-container text-on-primary flex-col -translate-x-full lg:translate-x-0 transition-transform flex">
    <div class="px-6 py-5 border-b border-on-primary-fixed-variant/30">
      <a href="/faculty" class="flex items-center gap-3">
        <img src="/img/gdcu-logo.png" alt="GDCU" class="h-10 w-auto object-contain">
        <span class="font-headline text-headline-sm font-bold leading-tight">GDCU<br/><span class="font-tagline text-label-sm text-secondary-fixed uppercase">Faculty Portal</span></span>
      </a>
    </div>
    <nav class="flex-1 py-4 space-y-1">
      <% const items = [
        ['dashboard','/faculty','Dashboard','dashboard'],
        ['students','/faculty/students','My Students','groups'],
        ['interviews','/faculty/interviews','My Interviews','event_available'],
        ['office','/faculty/office-hours','Office Hours','schedule'],
        ['schedule','/faculty/schedule','Schedule & Dates','date_range'],
        ['resources','/portal/library','Library','local_library']
      ]; %>
      <% items.forEach(function(it){ %>
        <a href="<%= it[1] %>" class="flex items-center gap-3 px-6 py-3 text-body-md <%= facultyActive===it[0] ? 'bg-on-primary-fixed-variant/30 border-l-4 border-secondary font-bold' : 'text-on-primary-container hover:bg-on-primary-fixed-variant/20' %>">
          <span class="material-symbols-outlined"><%= it[3] %></span><%= it[2] %>
        </a>
      <% }) %>
    </nav>
    <div class="px-6 py-4 border-t border-on-primary-fixed-variant/30">
      <a href="/" class="flex items-center gap-2 text-on-primary-container hover:text-secondary-fixed text-sm mb-3"><span class="material-symbols-outlined text-base">public</span> Main website</a>
      <form action="/logout" method="post"><button class="flex items-center gap-2 text-on-primary-container hover:text-secondary-fixed text-sm"><span class="material-symbols-outlined text-base">logout</span> Sign out</button></form>
    </div>
  </aside>

  <div class="flex-1 flex flex-col min-w-0">
    <header class="bg-surface-container-lowest border-b border-outline-variant px-6 py-4 flex items-center justify-between sticky top-0 z-30">
      <button id="fac-menu-btn" class="lg:hidden text-primary" aria-label="Menu"><span class="material-symbols-outlined">menu</span></button>
      <div class="flex-1"></div>
      <div class="flex items-center gap-4">
        <%- include('../partials/bell') %>
        <div class="w-9 h-9 rounded-full bg-primary-container text-on-primary flex items-center justify-center font-bold"><%= (currentUser.name||'F').charAt(0) %></div>
        <span class="hidden sm:inline font-bold text-primary text-sm">Dr. <%= currentUser.name %></span>
      </div>
    </header>
    <main class="flex-1 p-6 lg:p-8 max-w-6xl w-full mx-auto">
      <% if (flash.success.length || flash.error.length || flash.info.length) { %><%- include('../partials/flash') %><% } %>
      <%- body %>
    </main>
  </div>
</div>
<div id="fac-overlay" class="fixed inset-0 bg-black/40 z-30 hidden lg:hidden"></div>
<script>
  (function(){var b=document.getElementById('fac-menu-btn'),s=document.getElementById('fac-sidebar'),o=document.getElementById('fac-overlay');
  if(b)b.addEventListener('click',function(){s.classList.remove('-translate-x-full');o.classList.remove('hidden');});
  if(o)o.addEventListener('click',function(){s.classList.add('-translate-x-full');o.classList.add('hidden');});})();
</script>
</body>
</html>
