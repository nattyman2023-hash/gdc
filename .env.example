# ─────────────────────────────────────────────────────────────
# Global Diaspora Christian University — Environment Configuration
# Copy this file to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Public base URL (used for Stripe redirects, emails, canonical links)
APP_URL=http://localhost:3000
# Long random string — used to sign session cookies. CHANGE THIS in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Database ────────────────────────────────────────────────
# DB_CLIENT = "sqlite" for local development (no server needed)
#           = "mysql"  for Hostinger production
DB_CLIENT=sqlite

# SQLite (local dev) — relative path to the database file
SQLITE_FILE=./data/gdcu.sqlite

# MySQL (Hostinger) — fill these in from hPanel > Databases
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ─── Stripe (payments: application fees & tuition) ───────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Application fee in the smallest currency unit (e.g. 5000 = £50.00)
APPLICATION_FEE_AMOUNT=5000
APPLICATION_FEE_CURRENCY=gbp

# ─── Zoom (live classrooms and webinars) ─────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ─── Email ─────────────────────────────────────────────────────
MAIL_FROM="Global Diaspora Christian University <admissions@gdcu.edu>"
EMAILIT_FROM_EMAIL=admissions@gdcu.edu
EMAILIT_FROM_NAME="GDCU Admissions"

# Emailit (recommended) — transactional email + marketing audiences via API.
# Get your API key from https://app.emailit.com → workspace → API keys.
EMAILIT_API_KEY=
# Optional: an Emailit audience ID. When set, new leads/applicants/students
# are synced into it so staff can run newsletters/campaigns from Emailit.
EMAILIT_AUDIENCE_ID=

# Generic SMTP fallback (used only if EMAILIT_API_KEY is not set). Works with
# Emailit's own SMTP relay (host smtp.emailit.com, port 587, an SMTP-type
# credential as user/password) or any other provider (Brevo, SES, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── Support ──────────────────────────────────────────────────
SUPPORT_EMAIL=support@gdcu.edu

# ─── Logo / Branding Files (uploaded via Admin Settings) ──────
# SITE_LOGO=/uploads/logo.png
# SITE_FAVICON=/uploads/favicon.ico
