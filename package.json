{
  "name": "gdcu",
  "version": "0.1.0",
  "private": true,
  "description": "Global Diaspora Christian University — website, LMS & CRM platform",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:make": "knex migrate:make",
    "seed": "knex seed:run",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
    "setup": "node scripts/setup.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "connect-session-knex": "^4.0.0",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.11.0",
    "stripe": "^16.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
